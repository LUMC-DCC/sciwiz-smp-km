alse},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"ea64b7de-935f-4fa3-80ae-e5171fef7a0f","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"createdAt":"2025-10-02T16:29:20.992Z","entityUuid":"6cf4d1b8-63bd-4c47-bc1e-ff956cfbd89d","eventType":"EditChoiceEvent","label":{"changed":true,"value":"Data collection & instrumentation"},"parentUuid":"8e16d992-7891-46f7-9401-b1735821a3d2","uuid":"2360f567-ec01-4f03-a7e8-d86fbda59ba9"},{"annotations":{"changed":false},"createdAt":"2025-10-02T16:29:28.464Z","entityUuid":"388fb1cb-8467-4943-91c9-735171fd071c","eventType":"EditChoiceEvent","label":{"changed":true,"value":"Visualization & dissemination"},"parentUuid":"8e16d992-7891-46f7-9401-b1735821a3d2","uuid":"fa48cbe1-bf9f-4ab7-b6c0-874f49a8b72c"},{"annotations":{"changed":false},"createdAt":"2025-10-02T16:29:36.306Z","entityUuid":"16a6e396-9680-481f-a201-019a8390326e","eventType":"EditChoiceEvent","label":{"changed":true,"value":"Integration & interfacing"},"parentUuid":"8e16d992-7891-46f7-9401-b1735821a3d2","uuid":"420d42ae-ed4a-4af4-9a0f-cbdc664bb584"},{"annotations":{"changed":true,"value":[]},"createdAt":"2025-10-02T16:32:45.246Z","entityUuid":"c1a9b4b5-ad57-45a7-a89c-b3ede84e5926","eventType":"EditChoiceEvent","label":{"changed":false},"parentUuid":"8e16d992-7891-46f7-9401-b1735821a3d2","uuid":"b4408efa-4b2e-45f7-b0bc-75ad536d3d86"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2025-10-02T16:34:25.016Z","entityUuid":"8e16d992-7891-46f7-9401-b1735821a3d2","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"4f8bab10-7e62-472d-8fa2-b5dd10dfff6f","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What are the primary purposes of the software you develop?\n\n***Examples:***\n\n**Data collection & instrumentation**\n- Collecting patient-reported symptoms  \n- Integrating data from wearable health devices  \n- Web scraper for extracting data  \n- Interfacing with laboratory instruments  \n- Custom APIs for integrating data  \n- Software for controlling hardware  \n- Software for monitoring and logging  \n- AI-powered data acquisition systems (e.g., adaptive sampling, automated quality checks)\n\n**Data analysis**\n- Raw data pre-processing  \n- Script for statistical analysis  \n- Analyzing imaging data  \n- Custom machine learning models  \n- Pipeline for processing and analyzing data  \n- Implementing novel algorithms or methods  \n- Training AI models for prediction or classification  \n- Applying NLP models to extract information from text\n\n**Simulation**\n- Modeling processes  \n- Virtual simulation of procedures  \n- Computational models  \n- Using generative AI models to simulate complex systems  \n- Reinforcement learning for process optimization\n\n**Visualization & dissemination**\n- Plotting scripts  \n- Rendering images  \n- 3D visualizations  \n- AR/VR visualizations  \n- Generating reports from analysis results  \n- Creating interactive applications or dashboards  \n- Integrating AI-generated insights or summaries into visualizations\n\n**Software reuse**\n- Libraries or packages for specific tasks  \n- Pipelines  \n- Custom APIs  \n- Pretrained machine learning models  \n- Reusing AI components or models for transfer learning\n\n**Integration & interfacing**\n- APIs for integrating data  \n- Libraries for interfacing with specific tools  \n- Workflow management systems  \n- Data storage and retrieval systems  \n- Integrating AI services via APIs  \n- Deploying AI inference pipelines in production\n"},"title":{"changed":false},"uuid":"127ed721-2194-41f4-be90-d53ed81a1732"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-10-02T16:47:25.083Z","entityUuid":"941ece53-02a3-483f-b7a2-70e163f51472","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your software be registered with persistent identifiers (PID)?\nA PID is a globally unique, resolvable identifier such as DOI, RRID, Handle, or ARK."},"title":{"changed":false},"uuid":"8fa5d266-95d3-406d-8749-99c7a64696f5"},{"annotations":{"changed":false},"createdAt":"2025-10-02T16:47:58.481Z","entityUuid":"4c6711e9-3d42-4534-925a-7c15e15ead97","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"8c3ec1dc-eefa-439e-8c8d-a64f65e22559","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Specify the identifier system to be used for citing (and versioning) the software."},"title":{"changed":false},"uuid":"a649bcde-0432-4be6-92b6-58a03519b5e7"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-10-02T16:48:25.087Z","entityUuid":"621e355c-392c-4251-bf29-4a0ce610a7cf","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"4c6711e9-3d42-4534-925a-7c15e15ead97","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"3b8f2a6a-c033-4cf2-a0e9-8ab187799828"},{"advice":null,"annotations":[],"createdAt":"2025-10-02T16:48:36.893Z","entityUuid":"9af9bcc4-85d0-4fb4-ac9c-652ba60ab801","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"621e355c-392c-4251-bf29-4a0ce610a7cf","uuid":"3928f5c7-9531-46eb-ac89-bb4162f2140b"},{"advice":{"changed":false},"annotations":{"changed":