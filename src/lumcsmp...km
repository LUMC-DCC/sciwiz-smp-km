9-47c1-818b-a064c617561a"},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:03:34.248Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d969d3c6-1ba2-4c22-9937-c7b653c6a25f","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"93de1e6d-5cdf-4489-b96b-4eb839b5e429","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:04:25.17Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"integrationUuid":{"changed":true,"value":"00000000-0000-0000-0000-000000000000"},"parentUuid":"d969d3c6-1ba2-4c22-9937-c7b653c6a25f","props":{"changed":false},"questionType":"IntegrationQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"a893d76b-258a-46ee-8533-9a164fcfed37"},{"annotations":[],"createdAt":"2025-10-02T17:05:54.247Z","entityUuid":"5592e8d3-503c-4416-a345-21e327cc857e","eventType":"AddIntegrationEvent","id":"","integrationType":"ApiIntegration","itemUrl":null,"logo":null,"name":"","parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","props":[],"requestBody":"","requestEmptySearch":true,"requestHeaders":[],"requestMethod":"","requestUrl":"","responseItemId":null,"responseItemTemplate":"","responseListField":null,"uuid":"9285993b-66e9-484f-bd2b-36ce2c5a768f"},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:05:57.296Z","entityUuid":"5592e8d3-503c-4416-a345-21e327cc857e","eventType":"EditIntegrationEvent","id":{"changed":true,"value":"gh-licenses"},"integrationType":"ApiIntegration","itemUrl":{"changed":true,"value":"https://choosealicense.com/licenses/${id}/"},"logo":{"changed":false},"name":{"changed":true,"value":"GitHub Licenses"},"parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","props":{"changed":false},"requestBody":{"changed":false},"requestEmptySearch":{"changed":false},"requestHeaders":{"changed":true,"value":[{"key":"Accept","value":"application/vnd.github+json"},{"key":"User-Agent","value":"dsw-integration"}]},"requestMethod":{"changed":true,"value":"GET"},"requestUrl":{"changed":true,"value":"https://api.github.com/licenses"},"responseItemId":{"changed":true,"value":"{{item.key}}"},"responseItemTemplate":{"changed":true,"value":"**{{item.name}}** ({{item.spdx_id}})"},"responseListField":{"changed":true,"value":null},"uuid":"e8edf704-dafa-45cb-aa34-3c5e851715f3"},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:36:19.928Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"integrationUuid":{"changed":true,"value":"5592e8d3-503c-4416-a345-21e327cc857e"},"parentUuid":"d969d3c6-1ba2-4c22-9937-c7b653c6a25f","props":{"changed":false},"questionType":"IntegrationQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Specify the software license.\nThe license should be as open as possible, and as closed as necessary.\nRecommended license: [Apache 2.0](https://www.apache.org/licenses/LICENSE-2.0).\n\nIf you publish code without a license, you're keeping all rights reserved by default. That means nobody else (sometimes even you) has permission to use, modify, share, or extend your work even if it's publicly visible. Just compiling or running the software can constitute a violation. [Read more](https://choosealicense.com/no-permission/) about the implications of not licensing your software.\n\nSome helpful resources:\n- [Public License Selector](http://ufal.github.io/public-license-selector/) - An online wizard that asks you a series of questions (legal purposes, openness, commercial use) and suggests suitable licenses for your project. No prior legal knowledge required.\n- [ChooseALicense.com](https://choosealicense.com) - A GitHub-backed resource offering plain‑English explanations of common open-source licenses (MIT, GPL, Apache, etc.).\n- [Free Software Foundation (FSF) Licensing & Compliance Team](https://www.fsf.org/licensing/) - The FSFs Licensing & Compliance Team offers extensive guidance on free software licensing, including recommendations, GPL vs. other license compatibilities, FAQs, and compliance support.\n- [The Turing Way guide on licensing](https://the-turing-way.netlify.app/reproducible-research/licensing) - This guide explains how IP law and licensing shape who can legally use, modify, redistribute, or combine your code. It emphasizes that licensing decisions made early can directly affect your projects reach, collaborators, and impact.\n- [eScience Center guide on sharing software](https://esciencecenter-digital-skills.github.io/research-software-support/modules/licenses/how_to_share) - Warns that without a license you endanger reuse and derivative work—copyright and database rights can block reuse entirely. Encourages using standard licenses and explains how to legally and ethically share software. \n- [tl;dr Legal](https://www.tldrlegal.com) - Translates legal jargon into easy-to-understand summaries for popular software licenses. Developed by lawyers and peer-reviewed; helps identify obligations, restrictions, and risks without reading full legal texts. \n\n"},"title":{"changed":false},"uuid":"a6122c09-c80e-4613-8729-6ed108e9c500"},{"annotations":[],"color":"","createdAt":"2025-10-02T17:47:30.377Z","description":null,"entityUuid":"f4744cb8-0e29-4e67-8550-df51e05914ef","eventType":"AddTagEvent","name":"","parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"081cf0f1-6f06-4651-93f6-4bf9553cbc38"},{"annotations":{"changed":false},"color":{"changed":true,"value":"#2ECC71"},"createdAt":"2025-10-02T17:47:31.423Z","description":{"changed":true,"value":"This software is built for a specific, short-term purpose such as a single analysis or teaching example, with the developer as the main user. It’s small and easy to verify for correctness, often by visual inspection or simple tests. Since it’s not meant for reuse or long-term support, minimal maintenance is needed beyond basic documentation, versioning, and archiving.  (read more doi.org/10.5281/zenodo.7589725)"},"entityUuid":"f4744cb8-0e29-4e67-8550-df51e05914ef","eventType":"EditTagEvent","name":{"changed":true,"value":"Management Level: A"},"parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"8be48a13-2ade-44e6-a567-59e2ecc4b39a"},{"annotations":[],"color":"","createdAt":"2025-10-02T17:50:50.242Z","description":null,"entityUuid":"3c29bc4f-33e5-4ec2-b951-c7b7c0d7886e","eventType":"AddTagEvent","name":"","parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"7a625a6c-1bc2-4b3f-86c0-25ba8836c96f"},{"annotations":{"changed":false},"color":{"changed":true,"value":"#F1C40F"},"createdAt":"2025-10-02T17:50:51.287Z","description":{"changed":true,"value":"This software is typically a research output developed for a project but may be useful to others as a tool, module, or library. It should follow solid software practices - like version control, documentation, testing, and packaging - to ensure reliability and reusability. Because it can outlive the project, plans for archiving, citation, and long-term support are necessary.  (read more doi.org/10.5281/zenodo.7589725)"},"entityUuid":"3c29bc4f-33e5-4ec2-b951-c7b7c0d7886e","eventType":"EditTagEvent","name":{"changed":true,"value":"Management Level: B"},"parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"ec2d098e-a020-4b5e-87c6-59825932c812"},{"annotations":[],"color":"","createdAt":"2025-10-02T17:51:35.863Z","description":null,"entityUuid":"fab22389-4cc7-4aa8-abb7-a9a28d4bfeea","eventType":"AddTagEvent","name":"","parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"65da4b9e-a5ba-4478-8a14-3645756ab114"},{"annotations":{"changed":false},"color":{"changed":true,"value":"#E74C3C"},"createdAt":"2025-10-02T17:51:35.905Z","description":{"changed":true,"value":"This software has broad impact or critical use, such as being used by external users or influencing research results, models, or physical systems. Reliability is essential and requires rigorous engineering practices, testing, auditing, and compliance with legal or certification standards. It must be maintained indefinitely, supported by sustainable funding, community involvement, and continuous release pipelines."},"entityUuid":"fab22389-4cc7-4aa8-abb7-a9a28d4bfeea","eventType":"EditTagEvent","name":{"changed":true,"value":"Management Level: C"},"parentUuid":"b8a0346b-9127-4ed2-b9b5-e877135d419a","uuid":"2b05d2d3-ffa1-4995-8fed-d9fa3f2ffe08"},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:52:28.453Z","entityUuid":"14ee32a6-371a-431d-9cc3-189b67002e4c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":true,"value":["fab22389-4cc7-4aa8-abb7-a9a28d4bfeea"]},"text":{"changed":false},"title":{"changed":false},"uuid":"79e98a97-2f31-426c-b639-d2041e551c12","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2025-10-02T17:52:28.822Z","entityUuid":"ed466241-4c3a-49ae-9754-a8cf3dd7601d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":true,"value":["fab22389-4cc7-4aa8-abb7-a9a28d4bfeea"]},"text":{"changed":false},"title":{"changed":false},"uuid":"7e7c2ecf-fb7e-4778-af8a-84