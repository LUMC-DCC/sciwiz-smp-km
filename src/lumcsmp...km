ue":"Registries"},"uuid":"e208fbb9-02e2-4a72-beb0-863eb98e1111"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:34:56.033Z","entityUuid":"dd5216ff-dc89-489e-9591-a8365b88ce06","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List relevant software registries where the software is/will be findable.\nYou can find the list of popular software registries in the [Awesome Research Software Registries](https://github.com/NLeSC/awesome-research-software-registries)."},"title":{"changed":false},"uuid":"db6a43ab-46b3-4fdf-b22e-d075baa6f328","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T07:38:42.069Z","entityUuid":"4c6711e9-3d42-4534-925a-7c15e15ead97","eventType":"AddQuestionEvent","parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"dee22e78-3dd5-4be0-b88d-6309c119ad7a"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T07:38:45.106Z","entityUuid":"4c6711e9-3d42-4534-925a-7c15e15ead97","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Persistent identifier"},"uuid":"f4b9d399-4642-4a79-bd2a-155662e2aa05"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:38:55.896Z","entityUuid":"4c6711e9-3d42-4534-925a-7c15e15ead97","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Specify the identifier system (e.g., DOI) to be used for versioning and citing the software.\nIf your software already has an identifier, please provide it."},"title":{"changed":false},"uuid":"a39a06e2-60b3-411e-9ac5-ab1029d1ece6","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T07:42:23.731Z","entityUuid":"08005047-6408-4894-9df2-536dadbe443d","eventType":"AddQuestionEvent","parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"ac86b58c-4a15-4b7d-b1b3-388024843b48"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:42:26.765Z","entityUuid":"08005047-6408-4894-9df2-536dadbe443d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe how users should cite the software in publications or other projects. \nSpecify if a CITATION.cff file or similar will be used.\nIf you already have the  CITATION.cff file, please provide the link."},"title":{"changed":true,"value":"Citation"},"uuid":"092e4c7d-4089-4d7e-957d-c6a1815af190","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T07:44:03.211Z","email":"","entityUuid":"4b498204-d31c-4dd9-8fba-de66ec864557","eventType":"AddExpertEvent","name":"","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","uuid":"c7040871-325c-4480-bc49-526d4019c183"},{"createdAt":"2025-07-14T07:44:06.235Z","entityUuid":"4b498204-d31c-4dd9-8fba-de66ec864557","eventType":"DeleteExpertEvent","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","uuid":"0488140a-0d2e-45e4-8b0a-5b372243a4a3"},{"annotations":[],"createdAt":"2025-07-14T07:44:14.276Z","entityUuid":"7333b200-8daa-4f48-bafa-93d00fc25d12","eventType":"AddReferenceEvent","label":"","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","referenceType":"URLReference","url":"","uuid":"a290d982-e541-4455-b9c1-dad366ea2cce"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:44:16.301Z","entityUuid":"7333b200-8daa-4f48-bafa-93d00fc25d12","eventType":"EditReferenceEvent","label":{"changed":true,"value":""},"parentUuid":"08005047-6408-4894-9df2-536dadbe443d","referenceType":"URLReference","url":{"changed":true,"value":""},"uuid":"6e3da871-830e-4fa0-982c-d780b63c3dcb"},{"annotations":[],"createdAt":"2025-07-14T07:45:47.021Z","entityUuid":"4e0bc4fc-42d8-4438-8eff-92d16419c822","eventType":"AddReferenceEvent","label":"","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","referenceType":"URLReference","url":"","uuid":"8a0dc872-f453-4f75-a8b1-a4c697170830"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:45:47.05Z","entityUuid":"4e0bc4fc-42d8-4438-8eff-92d16419c822","eventType":"EditReferenceEvent","label":{"changed":true,"value":"CFF INIT (a tool to generate citation metadata and create CITATION.cff files)"},"parentUuid":"08005047-6408-4894-9df2-536dadbe443d","referenceType":"URLReference","url":{"changed":true,"value":"https://citation-file-format.github.io/cff-initializer-javascript/#/"},"uuid":"dfd7ac96-9de1-47b6-95b2-444e26fe9561"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:49:35.24Z","entityUuid":"08005047-6408-4894-9df2-536dadbe443d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe how users should cite the software in publications or other projects. \nSpecify if a CITATION.cff file or similar will be used.\nIf you already have the  CITATION.cff file, please provide the link.\n\nCITATION.cff is a human- and machine-readable file that provides citation metadata for software projects. When placed in a repository’s root, it enables platforms like GitHub to display a ready-to-use citation and integrates with tools like Zotero and Zenodo for proper attribution and DOI generation. This promotes best practices in software citation, making it easier for users to cite code correctly and for developers to receive academic credit.\n[Read more](https://the-turing-way.netlify.app/communication/citable/citable-cff.html#cm-citable-cff) about software Citation with CITATION.cff.\nYou can generate a CITATION.cff file using [CFF INIT](https://citation-file-format.github.io/cff-initializer-javascript/#/)."},"title":{"changed":false},"uuid":"fc460b56-665f-43aa-bf27-b1a0bdbab02f","validations":{"changed":false},"valueType":{"changed":false}},{"createdAt":"2025-07-14T07:51:55.426Z","entityUuid":"4e0bc4fc-42d8-4438-8eff-92d16419c822","eventType":"DeleteReferenceEvent","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","uuid":"ca0225d9-f5ad-45a7-a97d-85a3c92da3f6"},{"annotations":[],"createdAt":"2025-07-14T07:53:18.205Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"AddQuestionEvent","parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"29ea2c27-d50f-44b3-9551-b24417614e55"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T07:53:19.236Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Software license"},"uuid":"d04e5663-22eb-4d5d-8b8e-914fc1615ca7"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:53:28.861Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Specify the software license.\nThe license should be as open as possible, and as closed as necessary.\nRecommended license: [Apache 2.0](https://www.apache.org/licenses/LICENSE-2.0).\n\nIf you publish code without a license, you're keeping all rights reserved by default. That means nobody else (sometimes even you) has permission to use, modify, share, or extend your work even if it's publicly visible. [Read more](https://choosealicense.com/no-permission/) about the implications of not licensing your software.\n\nSome helpful resources:\n- [Public License Selector](http://ufal.github.io/public-license-selector/) - An online wizard that asks you a series of questions (legal purposes, openness, commercial use) and suggests suitable licenses for your project. No prior legal knowledge required.\n- [ChooseALicense.com](https://choosealicense.com) - A GitHub-backed resource offering plain‑English explanations of common open-source licenses (MIT, GPL, Apache, etc.).\n- [Free Software Foundation (FSF) Licensing & Compliance Team](https://www.fsf.org/licensing/) - The FSFs Licensing & Compliance Team offers extensive guidance on free software licensing, including recommendations, GPL vs. other license compatibilities, FAQs, and compliance support.\n- [The Turing Way guide on licensing](https://the-turing-way.netlify.app/reproducible-research/licensing) - This guide explains how IP law and licensing shape who can legally use, modify, redistribute, or combine your code. It emphasizes that licensing decisions made early can directly affect your projects reach, collaborators, and impact.\n- [eScience Center guide on sharing software](https://esciencecenter-digital-skills.github.io/research-software-support/modules/licenses/how_to_share) - Warns that without a license you endanger reuse and derivative work—copyright and database rights can block reuse entirely. Encourages using standard licenses and explains how to legally and ethically share software. \n- [tl;dr Legal](https://www.tldrlegal.com) - Translates legal jargon into easy-to-understand summaries for popular software licenses. Developed by lawyers and peer-reviewed; helps identify obligations, restrictions, and risks without reading full legal texts. \n\n"},"title":{"changed":false},"uuid":"28790e92-d554-4b5a-874b-7b30df448d7c","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T08:07:33.446Z","entityUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","eventType":"AddQuestionEvent","parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"384c3b8b-5360-44a4-aff0-d5292bd4aa81"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:07:36.486Z","entityUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"License compatibility"},"uuid":"c50c4cca-b74b-44b8-9ee5-7f48d4a984d8"},{"annotations":{"changed":false},"createdAt":"2025-07-14T08:07:38.537Z","entityUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your software respect the licences of dependencies it uses?"},"title":{"changed":false},"uuid":"a6d39a2e-8ea3-43d6-94d4-863989c6fa51","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:08:06.922Z","entityUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"79a2a8ed-97e3-428b-8f77-4bdab5405ba9"},{"advice":null,"annotations":[],"createdAt":"2025-07-14T08:08:27.412Z","entityUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","uuid":"7440352f-696f-49b2-b7ed-edefdc288f8e"},{"advice":{"changed":true,"value":null},"annotations":{"changed":false},"createdAt":"2025-07-14T08:08:30.432Z","entityUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","uuid":"9aa61c83-c05c-4e23-96d1-39eabeae3b29"},{"advice":null,"annotations":[],"createdAt":"2025-07-14T08:09:08.879Z","entityUuid":"9a3a53c2-ca0d-47ff-afc7-2d798d0e74ac","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","uuid":"aef890ef-8a41-43e9-a9ba-ed39c7c5457d"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2025-07-14T08:09:09.895Z","entityUuid":"9a3a53c2-ca0d-47ff-afc7-2d798d0e74ac","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","uuid":"2221e44a-cc17-4be0-818d-428450fbe9cd"},{"annotations":[],"createdAt":"2025-07-14T08:09:18.93Z","entityUuid":"46ce4557-de10-489f-8dab-8f094f0c1649","eventType":"AddQuestionEvent","parentUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"08ef8691-f88e-4639-8126-5c40ecfa881d"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:09:25.488Z","entityUuid":"46ce4557-de10-489f-8dab-8f094f0c1649","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Some resources for checking compatibility:\n- [The Turing Way guide on License Compatibility](https://book.the-turing-way.org/reproducible-research/licensing/licensing-compatibility.html) - This guide provides a practical overview of license compatibility. It explains what it means to combine code under different licenses, includes a permissions matrix to help visualize license compatibility, and walks through common scenarios, such as mixing MIT, GPL, and Apache-licensed code. \n- [GNU License List](https://www.gnu.org/licenses/license-list.html) - This list, maintained by Free Software Foundation (FSF), categorizes software licenses based on their level of freedom, copyleft strength, and compatibility with the GNU General Public License (GPL). It explains which licenses are compatible or incompatible with various versions of the GPL, and why. This is particularly important if youre using or contributing to GPL-licensed code\n\nNote on directionality: compatibility isn’t always mutual, e.g., MIT code can go into GPL projects, but not the other way around without relicensing."},"title":{"changed":true,"value":"How do/will you check that?"},"uuid":"b2fbfc32-45e1-41fe-bca8-5327d3ff2f4f"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:14:29.811Z","entityUuid":"e4e07b3f-d534-4670-9758-7df3ea315054","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your software respect the licences of dependencies it uses?\n\nLicense compatibility means the licenses of your project and its dependencies don’t conflict legally. It matters when you use third-party code, such as libraries or modules, because incompatible licenses can block you from distributing your software, force you to adopt more restrictive terms, or even introduce legal risk."},"title":{"changed":false},"uuid":"1e644e01-8bd2-4c11-bf4e-ab731a4e9696"},{"annotations":{"changed":false},"createdAt":"2025-07-14T08:26:25.57Z","entityUuid":"b350f7e4-5c40-4fe8-b0c4-b5ab8f485b4d","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Specify the software license.\nThe license should be as open as possible, and as closed as necessary.\nRecommended license: [Apache 2.0](https://www.apache.org/licenses/LICENSE-2.0).\n\nIf you publish code without a license, you're keeping all rights reserved by default. That means nobody else (sometimes even you) has permission to use, modify, share, or extend your work even if it's publicly visible. Just compiling or running the software can constitute a violation. [Read more](https://choosealicense.com/no-permission/) about the implications of not licensing your software.\n\nSome helpful resources:\n- [Public License Selector](http://ufal.github.io/public-license-selector/) - An online wizard that asks you a series of questions (legal purposes, openness, commercial use) and suggests suitable licenses for your project. No prior legal knowledge required.\n- [ChooseALicense.com](https://choosealicense.com) - A GitHub-backed resource offering plain‑English explanations of common open-source licenses (MIT, GPL, Apache, etc.).\n- [Free Software Foundation (FSF) Licensing & Compliance Team](https://www.fsf.org/licensing/) - The FSFs Licensing & Compliance Team offers extensive guidance on free software licensing, including recommendations, GPL vs. other license compatibilities, FAQs, and compliance support.\n- [The Turing Way guide on licensing](https://the-turing-way.netlify.app/reproducible-research/licensing) - This guide explains how IP law and licensing shape who can legally use, modify, redistribute, or combine your code. It emphasizes that licensing decisions made early can directly affect your projects reach, collaborators, and impact.\n- [eScience Center guide on sharing software](https://esciencecenter-digital-skills.github.io/research-software-support/modules/licenses/how_to_share) - Warns that without a license you endanger reuse and derivative work—copyright and database rights can block reuse entirely. Encourages using standard licenses and explains how to legally and ethically share software. \n- [tl;dr Legal](https://www.tldrlegal.com) - Translates legal jargon into easy-to-understand summaries for popular software licenses. Developed by lawyers and peer-reviewed; helps identify obligations, restrictions, and risks without reading full legal texts. \n\n"},"title":{"changed":true,"value":"Software license type"},"uuid":"8b6fad81-9575-4b45-8ba0-75542203af65","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:31:51.408Z","entityUuid":"46ce4557-de10-489f-8dab-8f094f0c1649","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"75a3e414-e4ce-4d9d-84f4-bc9698c99eb0"},{"annotations":{"changed":false},"createdAt":"2025-07-14T08:34:41.723Z","entityUuid":"46ce4557-de10-489f-8dab-8f094f0c1649","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1b99928b-ad57-46b8-a0b4-1d6e8193a06b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"dc34ef3f-cf80-43cf-9cc6-eb5fac371e1c","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"createdAt":"2025-07-14T08:37:08.806Z","entityUuid":"7333b200-8daa-4f48-bafa-93d00fc25d12","eventType":"DeleteReferenceEvent","parentUuid":"08005047-6408-4894-9df2-536dadbe443d","uuid":"ae140937-2afc-425f-ba06-7497d4897339"},{"annotations":[],"createdAt":"2025-07-14T08:38:27.603Z","entityUuid":"31841a99-9851-4306-bc77-a791a58bc143","eventType":"AddQuestionEvent","parentUuid":"991fac78-95fb-4486-a96f-f396e5f67e55","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"26bfd0c4-b0ee-4b59-80fd-9c12b43f2c69"},{"annotations":{"changed":false},"answerUui