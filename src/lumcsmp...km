":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your project include user documentation?"},"title":{"changed":true,"value":"User documentation"},"uuid":"0f4809c8-e2b8-4f70-81cd-f6be75cdd6a5"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:54:02.997Z","entityUuid":"36de65bd-3e04-45ae-ba94-95523bba73dd","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"991fac78-95fb-4486-a96f-f396e5f67e55","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your project include deployment documentation?"},"title":{"changed":true,"value":"Deployment documentation"},"uuid":"ce6a6755-53f0-417f-98be-70cce4b737b2"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T08:54:11.998Z","entityUuid":"8064d53a-73a2-4812-a377-ee911edbc645","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"991fac78-95fb-4486-a96f-f396e5f67e55","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does/will your project include developer documentation?"},"title":{"changed":true,"value":"Developer documentation"},"uuid":"a93f6d80-19d1-40be-84e6-9ab1b491a63b"},{"annotations":{"changed":false},"createdAt":"2025-07-14T08:56:00.584Z","entityUuid":"6f205c29-4fd3-4a3e-9e67-adb032c1c58c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"991fac78-95fb-4486-a96f-f396e5f67e55","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Outline the process for reporting bugs or requesting features, \nincluding where users can submit these and any templates to guide their input.\n\nFor example, [GitHub Issues](https://docs.github.com/en/issues/tracking-your-work-with-issues/about-issues) can be used to report bugs or request features, as it provides a clear, trackable way to manage contributions. GitHub's customizable issue templates and forms can be configured to pre-fill fields like titles, labels, and assignees, and even include form-style inputs. [Read more](https://docs.github.com/en/communities/using-templates-to-encourage-useful-issues-and-pull-requests/configuring-issue-templates-for-your-repository) to learn about configuring issue templates. "},"title":{"changed":false},"uuid":"b3a93a5c-91f7-42e3-96f2-1a115ebe4208","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T09:05:19.949Z","entityUuid":"acd9311d-530c-4b0c-88b6-dad738dc4f67","eventType":"AddQuestionEvent","parentUuid":"3507700c-768c-48c2-9242-eb1338191711","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"c6f7a494-f0fa-490e-ac18-d80018718012"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:05:20.983Z","entityUuid":"acd9311d-530c-4b0c-88b6-dad738dc4f67","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"3507700c-768c-48c2-9242-eb1338191711","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Test types"},"uuid":"eb73643c-b36f-4d6a-99b3-e655610d5f9f"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2025-07-14T09:05:26.185Z","entityUuid":"acd9311d-530c-4b0c-88b6-dad738dc4f67","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"3507700c-768c-48c2-9242-eb1338191711","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"req