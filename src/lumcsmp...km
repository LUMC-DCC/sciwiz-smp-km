ntityUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"d8983599-aad9-4258-b801-8cdb1209e1ff","uuid":"4e85aa6e-62ec-465a-9fda-bc712a703dc3"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2025-07-14T09:35:18.707Z","entityUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"d8983599-aad9-4258-b801-8cdb1209e1ff","uuid":"7217268d-107c-4f86-82bb-55834e33fe0b"},{"advice":null,"annotations":[],"createdAt":"2025-07-14T09:35:20.883Z","entityUuid":"68e68a7a-bd24-45ae-9ec3-67f239554354","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"d8983599-aad9-4258-b801-8cdb1209e1ff","uuid":"9afca361-6f3f-4abe-bdcd-7736334ba63c"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2025-07-14T09:35:21.198Z","entityUuid":"68e68a7a-bd24-45ae-9ec3-67f239554354","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"d8983599-aad9-4258-b801-8cdb1209e1ff","uuid":"0f503b09-b250-4c1a-9f45-3f2c2a69a75f"},{"annotations":[],"createdAt":"2025-07-14T09:35:28.317Z","entityUuid":"fd6b3084-4722-4695-81b2-014b7ab8ab94","eventType":"AddQuestionEvent","parentUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"fc715343-70b4-47e1-9035-713060fb6f4f"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:35:31.34Z","entityUuid":"fd6b3084-4722-4695-81b2-014b7ab8ab94","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"It is recommended to adopt a clear and consistent versioning strategy to help users and collaborators understand the stability and compatibility of your software over time. A common and widely accepted approach is semantic versioning, where version numbers follow the format MAJOR.MINOR.PATCH (e.g. 1.4.2). This approach communicates whether a release introduces breaking changes, new features, or bug fixes."},"title":{"changed":true,"value":"What versioning scheme do/will you follow?"},"uuid":"068c69b6-e033-49d7-93eb-1a91653b5855"},{"annotations":{"changed":false},"createdAt":"2025-07-14T09:37:23.875Z","entityUuid":"fd6b3084-4722-4695-81b2-014b7ab8ab94","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"7fb17632-bada-421b-aa80-5ec5bd7b9d49","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T09:37:56.748Z","entityUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","eventType":"AddQuestionEvent","parentUuid":"460a1edd-3307-40cf-aa3d-7c3f87564921","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"ed6c9081-f12f-4af0-8866-05df1488889f"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:37:59.78Z","entityUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"460a1edd-3307-40cf-aa3d-7c3f87564921","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"It is recommended to adopt a clear convention for commit messages to improve readability, traceability, and automation in your version control history. "},"title":{"changed":true,"value":"Do/will you follow a specific convention for writing commit messages?"},"uuid":"f2b0c8c4-136b-4ce0-b555-4d052f7bf9d9"},{"advice":null,"annotations":[],"createdAt":"2025-07-14T09:38:18.318Z","entityUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","uuid":"72ac9e7d-7535-442f-a0ca-780625bd93d9"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2025-07-14T09:38:19.339Z","entityUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","uuid":"0c0580be-a3fc-40ff-b99b-855fb415d9ce"},{"advice":null,"annotations":[],"createdAt":"2025-07-14T09:38:21.233Z","entityUuid":"47f70488-9ed1-4f66-9b76-252af69c8b73","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","uuid":"b9ee28a2-6d40-47e0-9cea-a09aee9d1aa1"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2025-07-14T09:38:21.467Z","entityUuid":"47f70488-9ed1-4f66-9b76-252af69c8b73","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"9abdc6e4-c414-4f64-917c-0826aebba301","uuid":"d444b8d2-882e-46a9-8ff0-36f99e9888b9"},{"annotations":[],"createdAt":"2025-07-14T09:38:25.2Z","entityUuid":"be2b412d-bbeb-4eba-ba01-cfd68b1898fe","eventType":"AddQuestionEvent","parentUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"1f915cc0-c9ec-4cfc-a7e7-e2e1c2f67988"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:38:47.966Z","entityUuid":"be2b412d-bbeb-4eba-ba01-cfd68b1898fe","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"A widely used approach is [Conventional Commits](https://www.conventionalcommits.org/en/v1.0.0/), which defines a structured format for messages (e.g., feat: add user login flow, fix: correct API URL) and enables automatic generation of changelogs and version bumps. \n\nCommit message conventions should be documented and, where possible, enforced using commit linters or hooks to ensure consistency across contributors."},"title":{"changed":true,"value":"What convention for writing commit messages do/will you follow?"},"uuid":"01e921b2-6182-4dee-bb07-74ae5d3d052d"},{"annotations":{"changed":false},"createdAt":"2025-07-14T09:39:23.884Z","entityUuid":"fd6b3084-4722-4695-81b2-014b7ab8ab94","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dfcb94bc-c930-420a-9710-cea9098ce522","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"A common and widely accepted approach is semantic versioning, where version numbers follow the format MAJOR.MINOR.PATCH (e.g. 1.4.2). This approach communicates whether a release introduces breaking changes, new features, or bug fixes."},"title":{"changed":false},"uuid":"7348683e-7944-49fe-a2c0-2a7db5a240c7","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:39:33.056Z","entityUuid":"d8983599-aad9-4258-b801-8cdb1209e1ff","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"460a1edd-3307-40cf-aa3d-7c3f87564921","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"It is recommended to adopt a clear and consistent versioning strategy to help users and collaborators understand the stability and compatibility of your software over time. "},"title":{"changed":false},"uuid":"b1e3cc2e-b927-41af-8fc5-5570b66bb4b9"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:40:33.721Z","entityUuid":"be2b412d-bbeb-4eba-ba01-cfd68b1898fe","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"0c0e6d7f-090f-4bc5-9be3-cc9532b8e65a"},{"annotations":{"changed":false},"createdAt":"2025-07-14T09:40:36.789Z","entityUuid":"be2b412d-bbeb-4eba-ba01-cfd68b1898fe","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"1ea9abc0-b03e-4786-aa59-10162597e0d4","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"b4042829-d44b-450e-8f6e-df9487ba0fc6","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T09:42:17.85Z","entityUuid":"9066be11-a412-4735-90cf-7286da07cd65","eventType":"AddQuestionEvent","parentUuid":"90ddd66e-41ff-4dcf-9fcd-299f6fdd4223","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"88a982cc-1586-49be-b33a-6c1a9794abd5"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T09:4