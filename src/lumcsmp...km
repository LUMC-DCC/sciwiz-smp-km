744a","eventType":"AddQuestionEvent","parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"c335084f-b8bb-4a7b-9a2a-46322d3dcdb9"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T07:28:14.302Z","entityUuid":"c7925796-45cb-4684-b1d6-108676ce744a","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Maintenance plan"},"uuid":"86e915f8-7254-4d70-a0ba-d7d9b762bebf"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:28:16.539Z","entityUuid":"c7925796-45cb-4684-b1d6-108676ce744a","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How do you plan to procure long term maintenance of your software? \nWhat level of support will be provided for users of the software and how will this support be organised? \nMake sure there are arrangements in place for the maintenance and reuse of your software."},"title":{"changed":false},"uuid":"2c4ee24b-2ef1-49c9-bd0d-98d0e80c6b37","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2025-07-14T07:28:53.906Z","entityUuid":"934609a8-e0fa-45bb-bb18-b63389994864","eventType":"AddQuestionEvent","parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"8788b6f3-ee01-4392-a9e2-6abe4cff6899"},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:28:55.948Z","entityUuid":"934609a8-e0fa-45bb-bb18-b63389994864","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"3d4c81c9-7cb1-41a7-8565-6fda0ff14403"},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe how the software will be retired, including how users will be informed and how data will be handled.\nInclude a plan for archiving the software and its documentation.\nSpecify the expected end-of-life date for the software.\nIf the software is to be maintained indefinitely, explain how this will be ensured."},"title":{"changed":true,"value":"Retirement plan"},"uuid":"323ff21c-44e3-4191-8fcc-4ec20fe2c95c","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:30:43.913Z","entityUuid":"ff6b3642-0ed2-466b-b7e5-30554af379ce","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How do you (plan to) procure development and long term maintenance of your software? \n- Plan resources for support-related activities such as training, hiring research software engineers, infrastructure, hardware, etc.. \n- The level of support should be in line with promises made regarding the level of service provided by your software.\n"},"title":{"changed":false},"uuid":"d58b3079-3603-4638-839d-dd117b14d78c","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:31:08.342Z","entityUuid":"c7925796-45cb-4684-b1d6-108676ce744a","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How do you (plan to) procure long term maintenance of your software? \nWhat level of support is provided for users of the software and how is this support be organised? \nMake sure there are arrangements in place for the maintenance and reuse of your software."},"title":{"changed":false},"uuid":"4e3146ca-73a7-4063-a6ff-45ab03955553","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2025-07-14T07:31:38.929Z","entityUuid":"934609a8-e0fa-45bb-bb18-b63389994864","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ceaad948-46e9-4248-8e66-891b905e3a8b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe how the software is pr will be retired, including how users are informed and how data is handled.\nInclude a plan for archiving the software and its documentation.\nSpecify the (expected) end-of-life date for the software.\nIf the software is to be maintained indefinitely, explain how this is ensured."},"title":{"changed":false},"uuid":"87c23c20-6d73-4fab-8f49-d8683461a27a","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":[],"createdAt":"2025-07-14T07:32:43.344Z","entityUuid":"5fd79a23-a383-4b54-9181-b0572ccca677","eventType":"AddQuestionEvent","parentUuid":"175900ac-d63a-4100-aaff-cc50b245953e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"fba4c82d-d5fa-45b1-9f79-d57cd9e4f776"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2025-07-14T07:32:43.374Z","entityUuid":"5fd79a23-a383-4b54-9181-b0572ccca677","eventType":"EditQues