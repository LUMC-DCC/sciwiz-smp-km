null,"title":"","uuid":"aa86b092-e41b-4582-a251-f9a7e8286454"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:13:08.399Z","entityUuid":"66898ced-0079-43ca-82f2-3c8d2050c87b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"292e1a9c-0f32-4338-b558-1ea17e23cbb5","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"fd08c186-34f3-4104-8715-702e8623393c"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":true,"value":"Status"},"uuid":"b4237a7b-cbc6-4e1f-9125-365654e53f6f"},{"advice":null,"annotations":[],"createdAt":"2026-06-08T13:13:18.144Z","entityUuid":"da90c752-3662-465c-bde1-84a268f460e5","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"66898ced-0079-43ca-82f2-3c8d2050c87b","uuid":"4e217425-7da2-4955-a9d5-65677ae30c47"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-06-08T13:13:20.181Z","entityUuid":"da90c752-3662-465c-bde1-84a268f460e5","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Officially supported"},"metricMeasures":{"changed":false},"parentUuid":"66898ced-0079-43ca-82f2-3c8d2050c87b","uuid":"d0b7c8ef-dab2-4536-ab3a-00f8389ea5bb"},{"advice":null,"annotations":[],"createdAt":"2026-06-08T13:13:44.775Z","entityUuid":"2baf901b-8cd9-473d-86f4-da93942913e7","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"66898ced-0079-43ca-82f2-3c8d2050c87b","uuid":"46528cb1-dfc8-4dd5-80e1-cba5456bd14b"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-06-08T13:13:44.816Z","entityUuid":"2baf901b-8cd9-473d-86f4-da93942913e7","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Expected to work"},"metricMeasures":{"changed":false},"parentUuid":"66898ced-0079-43ca-82f2-3c8d2050c87b","uuid":"59f811b4-9c73-4c49-af9f-6d27656b6265"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:14:40.858Z","entityUuid":"b419724b-9b15-4cf1-8ce8-66293b8b924f","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"718c82b8-f655-4265-9b6d-b7e37e66ad6b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does this project have automated tests?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#minimum-expectations-by-management-level) for more details."},"title":{"changed":false},"uuid":"3dcee42f-181e-4755-b53e-7e44e3685fcb"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-08T13:15:05.64Z","entityUuid":"03e51e53-de92-4de0-834c-f694b70a0218","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f0f36a7f-eea0-4d10-b0e6-4f5d36964b63","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Which types of tests do you include for your software? Match the testing depth to the project level and risk.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#test-types) for more details."},"title":{"changed":false},"uuid":"3828b028-aa27-42ed-ad9f-d3041b8facfb"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:15:20.574Z","entityUuid":"49bba8ab-1178-4695-a8b6-f8bfa61b1187","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f0f36a7f-eea0-4d10-b0e6-4f5d36964b63","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Which testing framework do you use? E.g., pytest (Python), testthat (R), Catch2 / GoogleTest (C++), built-in cargo test (Rust), JUnit 5 (Java), Vitest / Jest (JS/TS), bats-core (Bash).\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#test-frameworks) for more details."},"title":{"changed":false},"uuid":"aeb7dc70-ae40-432e-90bd-99d90477cc28","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:15:47.891Z","entityUuid":"54eb01df-650e-41fb-80ac-214f4c6dc4f5","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f0f36a7f-eea0-4d10-b0e6-4f5d36964b63","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project run tests automatically on every push or pull request?\n\nCommon CI platforms: GitHub Actions (default for open-source repos), GitLab CI.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#continuous-integration) for more details."},"title":{"changed":false},"uuid":"2a2d341e-1587-460e-894d-cdb48fa6c148"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:16:27.458Z","entityUuid":"3bef6b81-1655-42ea-9d79-0d225b6404ef","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"718c82b8-f655-4265-9b6d-b7e37e66ad6b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project use management tools for project configuration, dependencies, environments, or builds?\n\nE.g.: uv, Poetry, Hatch, Pixi (Python / cross-language); renv, rix (R); cargo (Rust); pnpm / npm (JS); Maven / Gradle (Java); CMake + Conan / vcpkg (C/C++); Snakemake, Nextflow (workflows).\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#project-dependency-management-tools) for more details."},"title":{"changed":false},"uuid":"69007156-10af-4301-bd70-c2c6b3814e73"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:16:55.542Z","entityUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"718c82b8-f655-4265-9b6d-b7e37e66ad6b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Do you follow specific software style guide and use tooling for linting/formatting? \n\nCommon combinations: ruff (Python — replaces black + isort + flake8); lintr + styler (R); built-in rustfmt + clippy (Rust); clang-format + clang-tidy (C/C++); eslint + prettier (JS/TS).\n\nType-checking is separate but worth adding: mypy / pyright (Python), built-in (TypeScript / compiled languages).\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/testing-quality/#code-quality-standards) for more details."},"title":{"changed":false},"uuid":"cd70638c-cc1b-4844-a690-f6c25653d26b"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:18:04.655Z","entityUuid":"73fcea4f-2631-4e91-8f79-ccf56dbb04b4","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f9f0867d-8ce4-4985-8c2c-966593149fdf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project use a version control system to track source-code changes?\n\nFor almost all research software, Git or another version-control system should be used from the start of active development.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/versioning-releases/#version-control) for more details."},"title":{"changed":false},"uuid":"3d92790e-fbee-46bc-86a6-cd75ac2f7cf1"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:18:43.515Z","entityUuid":"81cb4c8a-451a-4dcf-af86-dac5570ffb2f","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f9f0867d-8ce4-4985-8c2c-966593149fdf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project tag and publish releases?\n\nRecommendation: tag every release on main, create a GitHub/GitLab Release with a changelog, and connect to Zenodo for automatic DOI minting. Keep a CHANGELOG.md.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/versioning-releases/#releases) for more details."},"title":{"changed":false},"uuid":"948084c4-ebc0-4c10-a571-a334bf31d7c9"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:19:21.029Z","entityUuid":"88945da0-0593-4b36-8fa7-72f0e1d9fee6","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"2797b9ec-92e2-4c62-adf6-8e90b2e8f5a8","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How are version numbers assigned? E.g.: SemVer (MAJOR.MINOR.PATCH) for software with a stable API, CalVer (YYYY.MM.DD, YY.MM) for time-driven projects.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/versioning-releases/#versioning-scheme) for more details."},"title":{"changed":false},"uuid":"410d4064-ef99-412b-8b71-400615262952","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:19:51.976Z","entityUuid":"271bde84-6f27-4968-9261-94817f483c22","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f9f0867d-8ce4-4985-8c2c-966593149fdf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Do you package you software for distribution?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/versioning-releases/#software-packaging-and-distribution) for more details."},"title":{"changed":false},"uuid":"c73fe355-1ad2-492a-8070-fbb82e68d4a6"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:20:49.83Z","entityUuid":"e0d5b6b8-a6d4-4df1-987e-07e8cd8516a4","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"fd08c186-34f3-4104-8715-702e8623393c"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"94380087-2a87-46a1-b5de-579c2f0ec3b9","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:21:38.113Z","entityUuid":"2d28513a-2342-45a6-9fc7-641c355ca411","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"de478e18-2a3e-4349-804c-f1d8974897b1"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"80b5b012-3cbd-4d83-ba2c-0b3b6424336e"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:21:48.844Z","entityUuid":"0bd9cca6-2e0e-4b08-a54b-1b5b5847187c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"fd08c186-34f3-4104-8715-702e8623393c"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"b18534e2-987e-4446-be4f-bc198117a4de"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:22:00.149Z","entityUuid":"2d28513a-2342-45a6-9fc7-641c355ca411","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"45e406cc-d2f6-473c-b50a-5052644c2bda","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:22:06.643Z","entityUuid":"0bd9cca6-2e0e-4b08-a54b-1b5b5847187c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"72458718-1a2f-4fac-84a1-1dffa0680be7","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}}],"forkOfPackageId":null,"id":"lumc:rsmp:1.0.0","kmId":"rsmp","license":"CC-BY 4.0 ","mergeCheckpointPackageId":null,"metamodelVersion":17,"name":"LUMC-DCC Software Management Plan","nonEditable":false,"organizationId":"lumc","phase":"ReleasedPackagePhase","previousPackageId":"lumc:rsmp:0.0.6","readme":"# SMP knowledge model\n\nThis is Knowledge Model for creating **Software Management Plans (SMPs)** using the [Data Stewardship Wizard (DSW)](https://ds-wizard.org).  \nIt is designed to guide researchers and research software developers in documenting software development, sharing, maintenance, and reuse practices.\n\nThe knowledge model is currently deployed on the LUMC instance of DS Wizard: [SciWiz](https://sciwiz.lumc.nl/). Note it is only accessible via LUMC network. See more details in the [LUMC research software guidelines](https://lumc-dcc.github.io/rs-guidelines/smp/sciwiz/).\n\n## Feedback\n\nPlease use [GitHub Issues](https://github.com/LUMC-DCC/sciwiz-smp-km/issues) to provide feedback.  \nSee the issue templates for guided feedback.\n\n--- \n\n## License\n\nContents are licensed under the [Creative Commons Attribution 4.0 International (CC BY 4.0)](https://creativecommons.org/licenses/by/4.0/).\n\n","version":"1.0.0"}],"version":"1.0.0"}