a754a306d"},{"annotations":[],"createdAt":"2026-05-10T22:53:48.398Z","entityUuid":"1dd35b08-4394-44e5-a2e2-0d35228f6fd4","eventType":"AddQuestionEvent","parentUuid":"52a2dd0c-58ea-435c-b235-af77b1275d0c","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"6a67a9ce-d88e-415d-980f-c9209ee34bee"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:53:48.44Z","entityUuid":"1dd35b08-4394-44e5-a2e2-0d35228f6fd4","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"52a2dd0c-58ea-435c-b235-af77b1275d0c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How will users install the software?\n\nCommon channels: language package manager (PyPI / conda-forge / CRAN / Bioconductor / npm / crates.io); container image (Docker Hub / GitHub Container Registry / Quay / Apptainer Library / Biocontainers); source-only (`git clone && pip install -e .`); self-hosted installer; hosted as a service (the user calls your API)."},"title":{"changed":true,"value":"Distribution channels"},"uuid":"4718fcf9-5c53-4afb-a188-439190e29401"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:53:52.065Z","entityUuid":"1dd35b08-4394-44e5-a2e2-0d35228f6fd4","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"52a2dd0c-58ea-435c-b235-af77b1275d0c","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"cf486993-c125-4256-a1ef-8c6ac28c506f","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}}],"forkOfPackageId":null,"id":"lumc:rsmp:0.0.1","kmId":"rsmp","license":"CC-BY 4.0 ","mergeCheckpointPackageId":null,"metamodelVersion":17,"name":"LUMC-DCC Software Management Plan","nonEditable":false,"organizationId":"lumc","phase":"ReleasedPackagePhase","previousPackageId":null,"readme":"# SMP knowledge model","version":"0.0.1"},{"createdAt":"2026-05-10T23:09:47.187412Z","description":"A Knowledge Model for creating Software Management Plans (SMPs) ","events":[{"abbreviation":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:54:48.482Z","description":{"changed":true,"value":"The practical free-and-open-source-software properties, distinct from FAIR. A project can be partly FAIR and not FOSS (closed but well-documented), or FOSS and partly FAIR.\n\n> The score is computed as: score = Σ(weight × measure) / Σ(weight) over all answered questions that contribute to this metric. Each answer's measure is set on the answer itself; weights are set per (question, metric) pair. Skipped questions don't count. The result is in [0, 1]; the SMP report renders it as a percentage. Treat metric scores as a navigation aid, not a certification."},"entityUuid":"b681c5fb-2a05-4e19-be0e-6e5ccd13b58f","eventType":"EditMetricEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":{"changed":false},"uuid":"48234044-dcac-49bf-a012-b0b040f99a0e"},{"annotations":[],"createdAt":"2026-05-10T22:55:06.03Z","description":null,"entityUuid":"a664ce2c-83b0-411a-bdf5-4f829a4ecc25","eventType":"AddPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":"","uuid":"976de81a-c6fe-4bc7-910c-fed6241b4de5"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:06.048Z","description":{"changed":true,"value":"First steps before writing code: scope, motivation, risks, audience, resources."},"entityUuid":"a664ce2c-83b0-411a-bdf5-4f829a4ecc25","eventType":"EditPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":{"changed":true,"value":"Ideation"},"uuid":"9948e07d-4ae1-4778-9bb5-b4dc4e90900b"},{"annotations":[],"createdAt":"2026-05-10T22:55:12.28Z","description":null,"entityUuid":"de478e18-2a3e-4349-804c-f1d8974897b1","eventType":"AddPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":"","uuid":"fb60bc31-a792-4d3e-9250-00a7c59e6049"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:12.307Z","description":{"changed":true,"value":"Before writing code: scope, motivation, risks, audience, resources, and more specific technical decisions. Useful before submitting a grant proposal and starting active development."},"entityUuid":"de478e18-2a3e-4349-804c-f1d8974897b1","eventType":"EditPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":{"changed":true,"value":"Planning"},"uuid":"366b571b-3029-4845-a2ad-eb06b915d318"},{"annotations":[],"createdAt":"2026-05-10T22:55:17.751Z","description":null,"entityUuid":"fd08c186-34f3-4104-8715-702e8623393c","eventType":"AddPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":"","uuid":"76d3afcc-064e-4c06-b715-6e23808ae015"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:17.778Z","description":{"changed":true,"value":"While the software is being actively built. Most repository-, license-, version- and test-related answers should now point to concrete URLs or files."},"entityUuid":"fd08c186-34f3-4104-8715-702e8623393c","eventType":"EditPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":{"changed":true,"value":"Active development"},"uuid":"1df0d040-b5df-44e4-8114-b5d7f2c1e646"},{"annotations":[],"createdAt":"2026-05-10T22:55:23.579Z","description":null,"entityUuid":"92aed7aa-9d45-47f4-8a27-a1261e89aa5d","eventType":"AddPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":"","uuid":"32d9b2e3-4985-47af-8994-4e00581232a7"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:23.604Z","description":{"changed":true,"value":"After active development has slowed: bugfix releases, dependency updates, user support. Update the SMP at each new version or when policies change."},"entityUuid":"92aed7aa-9d45-47f4-8a27-a1261e89aa5d","eventType":"EditPhaseEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","title":{"changed":true,"value":"Maintenance"},"uuid":"b09fc1a2-0b60-4a39-900e-cee935f72c40"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:33.485Z","entityUuid":"68f0beb6-eaf7-4f1a-b7a3-b6cc0c875a38","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"a664ce2c-83b0-411a-bdf5-4f829a4ecc25"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"903e015d-8547-48f1-a5b1-bfac3646f04e","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:55:35.497Z","entityUuid":"c21e449e-8b43-403f-be68-dcb9e3abe7ba","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"de478e18-2a3e-4349-804c-f1d8974897b1"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"626edbc4-6c95-48c7-9740-08bbdd310cb6"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:37.123Z","entityUuid":"7ef49f2e-9981-421b-8a23-d1c5f181c741","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ef2a2194-5a5c-4eca-bac2-3d79fbeac9a7","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"de478e18-2a3e-4349-804c-f1d8974897b1"},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"7615c087-a71c-4501-adbc-1da4d22c5699"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:55:37.99Z","entityUuid":"334878d8-3202-4076-b634-658bb0663353","ev