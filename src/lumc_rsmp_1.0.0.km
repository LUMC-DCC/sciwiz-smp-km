ntUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Risk details"},"uuid":"266a2383-6478-47cd-8700-e62aef4aa9f2"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:03:42.18Z","entityUuid":"cb88ea86-0ffd-47e1-a3d3-de0da32c6d71","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Identify external software, data, hardware or services whose behavior, availability, or license may pose a long-term risk. Be realistic: focus on dependencies that would be expensive to replace, not every transitive package.\n\nFour archetypes worth flagging: vendor lock-in, unstable upstream API, abandoned upstream, proprietary data formats."},"title":{"changed":false},"uuid":"2c6f2ca7-615f-43d6-b3d8-a865b2d12245","validations":{"changed":false},"valueType":{"changed":true,"value":"TextQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T22:03:56.456Z","entityUuid":"01f03bbe-009c-4bef-98b3-2dcf3203d15b","eventType":"AddQuestionEvent","parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"659be346-686d-4609-9f5f-4edafdfc72df"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:03:56.485Z","entityUuid":"01f03bbe-009c-4bef-98b3-2dcf3203d15b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Mitigation"},"uuid":"7d041ce1-9b85-444e-9a77-511edfc354cb"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:03:59.237Z","entityUuid":"01f03bbe-009c-4bef-98b3-2dcf3203d15b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate."},"title":{"changed":false},"uuid":"d822d836-eecd-451f-bdaa-9a6d06277b3a","validations":{"changed":false},"valueType":{"changed":true,"value":"TextQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T22:04:36.741Z","entityUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","eventType":"AddQuestionEvent","parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"47c5ab62-6d7f-48db-8bbe-a0e61945c28e"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:04:36.777Z","entityUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Infrastructure & hardware"},"uuid":"9dd15057-ecfe-41de-a9c6-af0d102d434c"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:04:38.485Z","entityUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What physical or cloud infrastructure and hardware does the project need? E.g.: local servers, HPC allocations (Shark, SURF Snellius), cloud accounts, GPUs (model + VRAM), specialized lab instruments, storage tiers (Research Drive, Object Storage).\n\n**Does NOT include**: version-control hosting, package registries, documentation hosting."},"title":{"changed":false},"uuid":"c694770b-d6ff-44a5-a8b0-528ca55c7c76"},{"annotations":[],"createdAt":"2026-05-10T22:04:50.724Z","entityUuid":"623297ed-d432-470a-8c78-796472ee64d0","eventType":"AddQuestionEvent","parentUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"af9f4e98-5158-4177-b35a-270e93f61a75"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:04:53.748Z","entityUuid":"623297ed-d432-470a-8c78-796472ee64d0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Requirement"},"uuid":"84da9298-4c30-4765-8013-654d6d9cc8a0"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:04:56.252Z","entityUuid":"623297ed-d432-470a-8c78-796472ee64d0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"57232022-0ac1-4816-8b17-16d8153b66b2","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueTyp