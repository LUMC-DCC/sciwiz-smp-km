1b88b-d069-4a67-8299-29b64185ccd2","targetUuid":"2797b9ec-92e2-4c62-adf6-8e90b2e8f5a8","uuid":"30cd15d2-3155-482a-94a0-997b640f98a0"}],"forkOfPackageId":null,"id":"lumc:rsmp:0.0.6","kmId":"rsmp","license":"CC-BY 4.0 ","mergeCheckpointPackageId":null,"metamodelVersion":17,"name":"LUMC-DCC Software Management Plan","nonEditable":false,"organizationId":"lumc","phase":"ReleasedPackagePhase","previousPackageId":"lumc:rsmp:0.0.5","readme":"# SMP knowledge model","version":"0.0.6"},{"createdAt":"2026-06-09T11:21:19.714923Z","description":"A Knowledge Model for creating Software Management Plans (SMPs) ","events":[{"annotations":{"changed":false},"createdAt":"2026-06-05T12:59:16.174Z","entityUuid":"8653b1ff-adc4-47e1-8db8-429d28b168bd","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List **minimum two** people responsible for the software's development, maintenance, and support.\nWhy two? Single-maintainer projects regularly become orphans when the author leaves LUMC. A backup maintainer also makes review and merging possible. Please make sure that each maintainer has access to this SMP.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/identity/#authors-vs-maintainers) for more details."},"title":{"changed":false},"uuid":"d2ee961d-f013-4097-b2d7-3bf19403ad30"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:01:25.673Z","entityUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List existing software, libraries or pipelines that this project builds on, depends on, or interoperates with.\nIt makes lineage explicit, which is essential for citation and helps reviewers see what is genuinely new. This is not a full dependency manifest but rather a conceptual lineage."},"title":{"changed":false},"uuid":"434f2126-c05d-40d5-b781-b60a2c16be03"},{"advice":{"changed":true,"value":null},"annotations":{"changed":false},"createdAt":"2026-06-05T13:05:20.851Z","entityUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":false},"metricMeasures":{"changed":false},"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"497d0dbe-7d35-41b9-acfd-1ae84ca02d3a"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-05T13:06:30.013Z","entityUuid":"22746058-b1c4-498d-a39a-f5414f84b50f","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"cb896475-0d05-4cf4-8761-3fb3c0ee9223","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"To your knowledge, which specific legal, institutional, or regulatory requirements is the software subject to? Tick all regulatory or institutional regimes that apply."},"title":{"changed":false},"uuid":"b90835fb-bb0f-4154-8f41-22faa60224af"},{"advice":{"changed":true,"value":"A separate LUMC Data Management Plan is likely required. Confirm a central or your division's data steward. See [LUMC Data Stewardship](https://www.albinusnet.nl/actueel/themas/datastewardship/)."},"annotations":{"changed":false},"createdAt":"2026-06-05T13:09:29.245Z","entityUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":false},"metricMeasures":{"changed":false},"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"f811f8a7-39d0-48ad-ae29-a15538338449"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:10:55.714Z","entityUuid":"0a4c4dce-1969-48e1-a6e8-32dce8425d59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate.\n\nIf the mitigation risks are outlined in the DMP, say so explicitly. Check with your departmental SOP, if available."},"title":{"changed":false},"uuid":"34975fcd-aa96-4874-87d5-88b6d69fe61b","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:11:25.713Z","entityUuid":"ed90b3d1-b082-4156-b7d4-c7084e88e495","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"98569a9f-cf37-4451-9d20-4836b8187578","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate. Check with your departmental SOP, if available."},"title":{"changed":false},"uuid":"e3f2ac4e-51de-4c74-bbcb-49472636cd38","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-05T13:11:41.464Z","entityUuid":"67de93e1-e02c-4cef-ac98-91468f03006e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is the software subject to specific legal, institutional, or regulatory requirements? (E.g., GDPR, MDR, Institutional SOP). Check with your departmental SOP, if available."},"title":{"changed":false},"uuid":"fef4763e-726c-4a2a-b524-a034ffca87c4"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:11:55.722Z","entityUuid":"01f03bbe-009c-4bef-98b3-2dcf3203d15b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate. Check with your departmental SOP, if available."},"title":{"changed":false},"uuid":"1c222e1b-31e1-4eb9-ad12-c8fbbc8a551d","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":[],"createdAt":"2026-06-05T13:33:12.926Z","entityUuid":"eef8d842-6577-4383-be87-e6279739fdd3","eventType":"AddChoiceEvent","label":"","parentUuid":"22746058-b1c4-498d-a39a-f5414f84b50f","uuid":"46499c8d-7b66-4396-b0e7-b7c4f532d7dd"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:33:12.97Z","entityUuid":"eef8d842-6577-4383-be87-e6279739fdd3","eventType":"EditChoiceEvent","label":{"changed":true,"value":"Commissie Good Research Practice (GRP)"},"parentUuid":"22746058-b1c4-498d-a39a-f5414f84b50f","uuid":"e76c60c6-29c6-46b5-aa54-fa479cd14a9c"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:34:01.376Z","entityUuid":"7d2a4597-d792-4e5f-80a9-4f53fb16805b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ee641ccf-8f02-4191-a3cc-6f92b3e2f16c","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Recommendations: \n- LUMC GitLab (gitlab.lumc.nl) for private repositories; \n- GitHub for open-source projects intended for community use."},"title":{"changed":false},"uuid":"9b31ce5f-3c00-4a25-b6b4-6cc59bd95014","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:35:55.83Z","entityUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"206e6275-d142-4d29-8444-8f003555a0a1","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Which code quality practices will be used? Include formatting, linting, static analysis, type checking, code review, or style conventions. How do you enforce them? Prefer tools and configuration files over informal intentions."},"title":{"changed":false},"uuid":"be9961bb-87d7-420b-bf7b-c208dc1597e6"},{"annotations":[],"createdAt":"2026-06-05T13:36:57.253Z","entityUuid":"2d28513a-2342-45a6-9fc7-641c355ca411","eventType":"AddQuestionEvent","parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"6da3c1d9-0ee8-4c64-b3b9-5abf27bc35ea"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-05T13:36:57.289Z","entityUuid":"2d28513a-2342-45a6-9fc7-641c355ca411","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Standard"},"uuid":"d628251c-56fa-47dd-ac69-a92d484ce450"},{"annotations":[],"createdAt":"2026-06-05T13:37:01.203Z","entityUuid":"0bd9cca6-2e0e-4b08-a54b-1b5b5847187c","eventType":"AddQuestionEvent","parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"cef7242b-456d-4c95-80f7-b4d6a25f7ddb"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-05T13:37:02.24Z","entityUuid":"0bd9cca6-2e0e-4b08-a54b-1b5b5847187c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"f4d82807-04f4-40f6-965f-0958821f1cb9","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Enforcement"},"uuid":"e1e55dce-e094-4485-adb0-1e2504d2c80c"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:38:56.808Z","entityUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","eventType":"EditChapterEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","questionUuids":{"changed":false},"text":{"changed":true,"value":"> Throughout the SMP, present-tense questions (\"Is…\", \"Does…\", \"Has…\") describe the intended state at the relevant project phase. For projects in planning, read these as \"is or will be\"; for active or maintenance projects, read them at face value. The phase tag on each question shows when the answer is normally expected to harden into a concrete reference.\n\nIdentify the project, the people responsible, and any external regulatory regime that applies. Keep this section short: detail belongs in the thematic chapters that follow.\n\nIf you're unsure about the management level (A / B / C) you've selected for the project, see the [guidelines](https://lumc-dcc.github.io/rs-guidelines/smp/sciwiz/#management-levels) before proceeding."},"title":{"changed":false},"uuid":"7cf952b6-4531-41df-9a12-5226514ee3ca"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:40:03.83Z","entityUuid":"68f0beb6-eaf7-4f1a-b7a3-b6cc0c875a38","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Provide a clear, descriptive, unique title for the software: the name people use to cite, search and refer to it. Specific enough that someone unfamiliar with the project understands what it is broadly about; short enough to fit on a slide and a CLI prompt.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/identity/#software-title) for more details."},"title":{"changed":false},"uuid":"7aee6f06-65d6-4a4b-b7e8-34e7d79b1d1c","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-05T13:40:39.746Z","entityUuid":"c21e449e-8b43-403f-be68-dcb9e3abe7ba","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is the development of the software funded?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/identity/#funding-and-project-context) for more details."},"title":{"changed":false},"uuid":"b1b70427-7a45-4b80-a941-29a709d929d9"},{"annotations":{"changed":false},"createdAt":"2026-06-05T13:41:10.149Z","entityUuid":"d6d0744c-c21c-454c-a17e-f7be0ae12f58","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List the people who should be credited as authors of the software in citations, registries (Zenodo, Software Heritage) and the CITATION.cff file. A reasonable rule of thumb: someone is an author if they would be listed as an author on the paper that describes this software, were it written today.\n\nFor most projects, **Maintainers ⊆ Authors ⊊ Contributors**.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/identity/#authors-vs-maintainers) for more details."},"title":{"changed":false},"uuid":"bb9da4f8-1efa-4e5a-aaad-bc37a1785c84"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-05T13:42:05.718Z","entityUuid":"01a015c3-db75-4376-a04f-95c947bff24b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is this software a Software as a Medical Device (SaMD), an in-vitro-diagnostic (IVD) product, or otherwise subject to a sectoral regulatory regime (MDR, IVDR, FDA, etc.)?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/identity/#the-regulated-software-flag) for more details."},"title":{"changed":false},"uuid":"b0b81cd0-4b85-4e73-a40e-6580e8f4d1a0"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-08T12:27:51.287Z","entityUuid":"4a580662-68da-4401-a624-2a654b5aa544","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What are the primary purposes of this software? Select all that apply. Use the most specific category you can.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/motivation-scope/#purpose-categories) for more details."},"title":{"changed":false},"uuid":"72af286e-13fe-4ad1-8332-61c74cbe3968"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:30:14.938Z","entityUuid":"e0da89c9-fba6-43fc-93ac-7424643269c9","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe the main research or technical problem that this software addresses. Aim for 2–4 sentences that an expert from another sub-field could understand: what is the problem, who suffers from it, why a software solution is appropriate. See [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/motivation-scope/#the-problem) for more details."},"title":{"changed":false},"uuid":"e571eb7d-a30a-41be-86eb-a2146345cccb","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-08T12:31:11.324Z","entityUuid":"76472d8f-df59-49fc-8726-9091e0c930a0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Who is the intended audience or primary user group? Pick the most specific categories that apply. See [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/motivation-scope/#audience) for more details."},"title":{"changed":false},"uuid":"1e0dcb90-0bd2-4e4d-945d-32c78a308bbf"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:32:05.408Z","entityUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List existing software, libraries or pipelines that this project builds on, depends on, or interoperates with.\nIt makes lineage explicit, which is essential for citation and helps reviewers see what is genuinely new. This is not a full dependency manifest but rather a conceptual lineage. See [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/motivation-scope/#related-and-upstream-software) for more details."},"title":{"changed":false},"uuid":"506de368-aaf8-469d-8c78-682731fe75d8"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:32:38.194Z","entityUuid":"c177f774-cda9-44e5-bb7a-03dea1580664","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"2f8a5871-b095-4c59-962d-9609220c2f0a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe\n* what makes this software valuable compared to existing alternatives, and \n* why developing new software is justified rather than contributing to or reusing an existing tool.\n\nIf no real alternative exists, say so - that is itself a strong justification. If you are extending an existing tool, name it in the previous question and explain what was missing.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/motivation-scope/#justify-the-existence-of-a-new-project) for more details."},"title":{"changed":false},"uuid":"51634de2-bfd7-428c-acac-faee8cf10b73","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:36:16.809Z","entityUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does this software handle personal or otherwise sensitive data?\n\n- **Yes** if your code reads, stores, transmits or processes such data as part of its normal operation (e.g., a Castor extraction script, a clinical-decision-support API).\n- **User-supplied only** if your code is a generic library/CLI/tool that can be used with personal data when the user feeds it that data, but does not handle such data itself (e.g., a statistical analysis library, a plotting tool).\n- **No** if neither applies (e.g., a synthetic-data tool, a build-tool plugin).\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#personal-and-sensitive-data) for more details."},"title":{"changed":false},"uuid":"caad8360-071d-4f0e-8577-4036fe4eb900"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:36:47.374Z","entityUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the software face operational security obligations: authentication, authorization, input sanitization, secret management, vulnerability scanning?\n\nThese usually apply to services, APIs, and daemons. Pure libraries, scripts, and notebooks normally do not face these obligations directly. See [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#security-access-control) for more details."},"title":{"changed":false},"uuid":"183b2468-7238-474b-ae50-9d43c8ac3e25"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:37:24.426Z","entityUuid":"67de93e1-e02c-4cef-ac98-91468f03006e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is the software subject to specific legal, institutional, or regulatory requirements? (E.g., GDPR, MDR, Institutional SOP). Check with your departmental SOP, if available.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#compliance-regulatory-considerations) for more details."},"title":{"changed":false},"uuid":"c5540fb8-eb88-44de-9c38-cb3635ccef40"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:38:45.007Z","entityUuid":"1e3700a0-0ebe-4499-a95c-caa6eb2b2974","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the software face (long-term) risks in external software, data, hardware or services whose behavior, availability, or license?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#external-dependency-risks) for more details."},"title":{"changed":false},"uuid":"f96c146c-4eb9-4036-beeb-ee4cbf78f021"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:40:02.189Z","entityUuid":"0a4c4dce-1969-48e1-a6e8-32dce8425d59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate.\n\nIf the mitigation risks are outlined in the DMP, say so explicitly. Check with your departmental SOP, if available.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#risk-mitigation) for more details."},"title":{"changed":false},"uuid":"32e9deab-f8af-4cab-b19d-38061c8972d5","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:40:23.892Z","entityUuid":"8b4d40a6-3be6-40b5-8219-b3f4431a4c40","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Briefly describe the design choices that prevent inadvertent data leakage: no telemetry by default, no caching of inputs, log scrubbing, clear instructions for users to anonymize upstream or run in a controlled environment.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#risk-mitigation) for more details."},"title":{"changed":false},"uuid":"423f8df8-db67-4164-aee7-6fbb656bbd67","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:40:43.123Z","entityUuid":"ed90b3d1-b082-4156-b7d4-c7084e88e495","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"98569a9f-cf37-4451-9d20-4836b8187578","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate. Check with your departmental SOP, if available.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#risk-mitigation) for more details."},"title":{"changed":false},"uuid":"26fcf3d4-ae6b-4739-a41c-e4b8ec67e092","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:41:10.504Z","entityUuid":"01f03bbe-009c-4bef-98b3-2dcf3203d15b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate. Check with your departmental SOP, if available.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/risks/#risk-mitigation) for more details."},"title":{"changed":false},"uuid":"55ef0b36-8d74-48df-929a-155d4997d2a0","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:43:52.239Z","entityUuid":"15094ec5-2f5b-4bcb-944e-5c76b70f9975","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What physical or cloud infrastructure and hardware does the project need? E.g.: local servers, HPC allocations (Shark, SURF Snellius), cloud accounts, GPUs (model + VRAM), specialized lab instruments, storage tiers (Research Drive, Object Storage).\n\n**Does NOT include**: version-control hosting, package registries, documentation hosting.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#infrastructure-hardware) for more details."},"title":{"changed":false},"uuid":"87df69ba-6bb4-4e7e-a0fa-f63401593cc3"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:44:29.967Z","entityUuid":"9bbd58d5-d341-4d4a-b790-2127c5abe948","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What external services, partners, or roles do you need from outside your immediate team? Examples: institutional IT/DCC, paid SaaS, hosted CI minutes, legal/contractual support, external review/audit.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#external-services) for more details."},"title":{"changed":false},"uuid":"7062cf83-c663-4ea2-9fda-8e52cdcc4ff0"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:45:32.641Z","entityUuid":"20ecbd93-d2cf-4903-a845-fe8766f44ad7","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List expertise needed to develop, review, deploy, or maintain the software. Focus on gaps that could affect delivery or sustainability: research software engineering, data stewardship, security, regulatory expertise, DevOps, UX, domain knowledge, statistics, testing, documentation, or community management.\n\nBe specific: \"Python packaging\", \"clinical workflow validation\", \"GitHub Actions CI\" is better than \"programming\". \nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#expertise) for more details."},"title":{"changed":false},"uuid":"ccfe8e2e-5597-443b-b6c7-07e364245a7d"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:46:33.241Z","entityUuid":"1e0f8cf3-1c0b-4d2c-aeb9-6c4e203ca7a1","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Estimate the development effort needed to reach a usable version of the software. Use a unit that fits the project: person-days, person-months, FTE over time, sprint count, student project duration, or grant work-package effort.\n\n**Recommended format**: `<FTE-fraction> for <duration>`, e.g., *0.5 FTE for 18 months* or *1.0 FTE-month one-off*. Order-of-magnitude is enough.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#development-effort) for more details."},"title":{"changed":false},"uuid":"78b0cc77-054b-4c2c-a476-51faafecc5d6","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:47:00.673Z","entityUuid":"d98ca02c-02d1-42a9-97fa-c549d25f3e3b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project receive maintenance and updates? (e.g., bug fixes, security patches, feature enhancements).\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#updates-maintenance) for more details."},"title":{"changed":false},"uuid":"3dbf7438-bf11-45b9-b28a-4c4fe313cfc8"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-08T12:47:25.289Z","entityUuid":"0a31022a-9c47-4039-933f-033f74d822db","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Select conditions under which the software should be retired, archived, or declared unsupported. Retirement does not always mean deletion; for research software it usually means no new development, clear archival status, and preserved access to relevant releases.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#retirement-criteria) for more details."},"title":{"changed":false},"uuid":"f9a34157-d046-406e-b930-43c1a91664a1"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:48:16.14Z","entityUuid":"ffbaf875-9ada-42cd-ad34-046a55ee4eab","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"61a3dcff-803f-41c3-9e14-5fa1fb5492c3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Estimate the effort needed to maintain the software after first use or release. Include expected bug fixes, dependency updates, user support, documentation updates, compatibility testing and release work.\n\n**Recommended format**: `<FTE-fraction> per year`. 0 is acceptable, but only if you have an explicit retirement plan.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#maintenance-effort) for more details."},"title":{"changed":false},"uuid":"2c2f1f03-2296-4746-a265-9cb4a6f1a97d","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:48:51.56Z","entityUuid":"6438ee04-535a-4991-ac67-b3e2c924a058","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"61a3dcff-803f-41c3-9e14-5fa1fb5492c3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe what happens if the main developer, maintainer, funding source, or infrastructure becomes unavailable.\n\nExamples of viable answers: backup maintainer with full rights; community fork on day one; archived repository; hand-over to <new responsible entity> at end of grant.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#continuity-hand-over) for more details."},"title":{"changed":false},"uuid":"cdcf803c-611e-4bae-bf17-5c00476b51a4","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:49:20.456Z","entityUuid":"e3f669c3-3055-4bb5-83df-767a52630d37","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"222b5f2e-0b72-4e5c-b1ec-ac1e5f88bacf","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Will the retired software remain accessible in a read-only, archived, or otherwise retrievable form? Answer \"Yes\" only if users will be able to find the relevant code, release, documentation, and metadata after active maintenance ends.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/planning/#post-retirement-accessibility) for more details."},"title":{"changed":false},"uuid":"2aec9c63-c266-45f5-b294-3fc82b016faf"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:50:54.677Z","entityUuid":"bcd77cf1-06b8-4867-a7a5-3dcdf5f72b04","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d93d3f14-7bab-440c-8369-d9f6b299e976","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is the source code in a version-controlled repository?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#repository) for more details."},"title":{"changed":false},"uuid":"0766c189-a017-4a15-b7d8-6bad6282f753"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:52:00.013Z","entityUuid":"fffa48cd-dd60-4c7c-a7de-61f4799f936e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d93d3f14-7bab-440c-8369-d9f6b299e976","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Is the software listed in community registries? A *registry* is a metadata catalogue (e.g., bio.tools, Research Software Directory), distinct from a package repository that hosts installable artefacts (PyPI, conda-forge, Docker Hub).\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#registries) for more details."},"title":{"changed":false},"uuid":"9a75c32d-9617-4032-bb31-0770f5c97727"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:52:50.308Z","entityUuid":"fe9a0536-34a2-4637-82c1-658f281354b3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d93d3f14-7bab-440c-8369-d9f6b299e976","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the software have a persistent identifier (PID): a stable, resolvable URL that survives platform migrations and renames? The most common PID is a **DOI** minted by Zenodo when you archive a tagged release.\n\nRecommended workflow: connect your repo to Zenodo → push a tag → create a Release → Zenodo mints a version-DOI and a concept DOI that always points to the latest version.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#persistent-identifiers) for more details."},"title":{"changed":false},"uuid":"e35a2a8f-7e20-4c4c-9628-4227af623935"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:53:27.06Z","entityUuid":"c8c95984-07e6-438c-abfd-00b8f7a669c0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d93d3f14-7bab-440c-8369-d9f6b299e976","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Are there published method papers or preprints for or associated with this software?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#publications) for more details."},"title":{"changed":false},"uuid":"8b6c88fd-1a04-4bef-937c-a229d1d3d6a6"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:54:30.108Z","entityUuid":"056a24f7-9201-4add-a339-5abff6137c59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"d93d3f14-7bab-440c-8369-d9f6b299e976","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does this software include a license?\n\nWithout a license, code is \"all rights reserved\" by default, even if it is publicly visible: no one (sometimes even you) can legally reuse, fork, or build on it. \"Public on GitHub\" is not the same as \"open source\".\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#software-license) for more details."},"title":{"changed":false},"uuid":"bbf9fa0d-5d0b-4cbe-a86e-29c92284ab76"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:55:00.026Z","entityUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ce2b567a-da20-43be-a121-e677415a8e0c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Do you check if your dependencies' licenses are compatible with your project's license?\n\nLicense compatibility means the licenses of your project and its dependencies don't conflict legally. It matters when you use third-party code, such as libraries or modules, because incompatible licenses can block you from distributing your software, force you to adopt more restrictive terms, or even introduce legal risk.\n\nTooling: licensecheck / pip-licenses (Python), cargo-deny (Rust), license-checker (Node), FOSSA / Snyk / GitHub Advanced Security (cross-language).\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/sharing-licensing/#license-compatibility) for more details."},"title":{"changed":false},"uuid":"09cd6e30-8c97-40f6-bca3-06a99492a759"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:55:47.907Z","entityUuid":"21768d54-f8f8-4329-a706-ab7a008b6ea6","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"bc0b7898-1dd3-4dc2-8879-ffa3f6ea4c8e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project have user-facing documentation: installation, configuration, usage instructions, at least one runnable example?\n\n- Minimum: a good README answering what / who / how to install / how to run / how to cite / license / how to get support. \n- Preferably: a documentation site (MkDocs, Sphinx+MyST, Quarto, Docusaurus) hosted on Read the Docs / GitHub Pages / GitLab Pages.\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/documentation-community/#user-documentation) for more details."},"title":{"changed":false},"uuid":"ce426071-cbf1-4f02-aaed-42fc4a19a5ec"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:58:19.458Z","entityUuid":"6eb788b0-bcae-4152-b8ee-8cb97bf5c692","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"bc0b7898-1dd3-4dc2-8879-ffa3f6ea4c8e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project document how to install, deploy or run the software, including dependencies and environment setup? For reusable or reproducible software, users should not have to infer the environment from source code.\n\nDependency manifests (the machine-readable lock files (pyproject.toml, requirements.txt, environment.yml, Dockerfile, renv.lock, Cargo.lock, etc.)) is requested in Interoperability chapter.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/documentation-community/#deployment-dependency-documentation) for more details."},"title":{"changed":false},"uuid":"588ec144-102d-48f1-9e45-aa91a5396b37"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:58:39.408Z","entityUuid":"afa46dc9-6ca3-4924-aa15-bd015b070cfa","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"bc0b7898-1dd3-4dc2-8879-ffa3f6ea4c8e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project have developer-facing documentation: code organization, build process, how to add a feature, how to run the test suite? The level of detail should match the project level.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/documentation-community/#developer-documentation) for more details."},"title":{"changed":false},"uuid":"5f23dc67-9e7b-4f45-a780-c3b538ce9ff9"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T12:59:04.208Z","entityUuid":"ce3cc455-a9c7-4c83-b077-15e43b789071","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"bc0b7898-1dd3-4dc2-8879-ffa3f6ea4c8e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Do users or collaborators have a clear route to report bugs, request features, or ask support questions? This can be an issue tracker, helpdesk, email address, form or documented contact route.\n\nRecommendation: GitHub or GitLab issue tracker, with issue templates.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/documentation-community/#bug-reporting-feature-requests) for more details."},"title":{"changed":false},"uuid":"15b98c3b-37da-426b-a338-63d4d33c8f66"},{"annotations":{"changed":false},"createdAt":"2026-06-08T12:59:30.041Z","entityUuid":"33bc112f-ea2a-402a-92c5-b0eec540e684","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"bc0b7898-1dd3-4dc2-8879-ffa3f6ea4c8e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How are decisions made when contributors disagree? Who handles releases, docs, security disclosure? What is the decision-making model (lazy consensus / BDFL / formal voting), conflict-resolution path?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/documentation-community/#governance) for more details."},"title":{"changed":false},"uuid":"fa5eeef0-4af4-4a62-b406-fa6e3f7cf999","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:00:00.041Z","entityUuid":"d5af5796-82a6-4450-8e78-02f3d4ec049b","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List the programming languages used in this project, with versions or version constraints.\n\n- The primary language of the codebase.\n- Any glue languages with non-trivial logic: workflow DSLs (Snakemake, Nextflow, WDL, CWL), Make/CMake, Bash scripts.\n- For container-heavy projects, name the workflow languages.\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#programming-languages) for more details."},"title":{"changed":false},"uuid":"e22ea640-b47b-4c1c-8fc5-ca76ab53654a"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:01:39.789Z","entityUuid":"ed5d2980-ecaa-4654-a6a8-8a8dff5920fb","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List data formats the software can read or import. Prefer controlled EDAM format terms (or any open, standard, and documented formats) where available. Include constraints only when they matter for interoperability.\n\nSkip if your software does not consume external data.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#input-and-output-data-formats) for more details."},"title":{"changed":false},"uuid":"52ad2998-b766-44c4-92bc-c3764ada7d28"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:02:35.973Z","entityUuid":"8bd89f26-dd51-47a8-b3df-131906f79db2","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List data formats the software writes, exports or emits. Prefer controlled EDAM format terms (or any open, standard, and documented formats) where available. Include constraints only when they matter for interoperability.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#input-and-output-data-formats) for more details."},"title":{"changed":false},"uuid":"0b727b1d-88f5-42ea-b01c-7f66cb458509"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:02:40.511Z","entityUuid":"06b6d6d9-5942-4a2a-aecb-6bc9336505e3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"List the functions and operations the software performs.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#functions-operations) for more details."},"title":{"changed":false},"uuid":"32403cd4-a9a7-4825-b4ba-1d81678a6e96"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-06-08T13:03:00.823Z","entityUuid":"292e1a9c-0f32-4338-b558-1ea17e23cbb5","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"MultiChoiceQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Which operating systems (e.g., Linux, macOS, Windows, HPC) and architectures does the software support?\n\nDistinguish *supported* (CI-tested, advertised, bugs accepted) from *expected to work* (used by maintainers but no CI). Pure-runtime languages (Python/R/Java/JS without native deps) usually work everywhere.\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#cross-platform-compatibility) for more details."},"title":{"changed":false},"uuid":"3b0d9fa7-90cb-42da-b877-e7da32eae473"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:04:06.511Z","entityUuid":"48321dbc-9069-437a-8a71-0fd37ab2d226","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe typical and worst-case hardware resources required to run the software.\n\nUseful structure:\n```\nMemory     : ~1 GB typical, up to 16 GB for whole-genome inputs\nStorage    : ~200 MB code; ~5 GB for a representative input dataset\nCompute    : 1–8 CPU cores typical; scales linearly to 32 in batch mode\nGPU        : NVIDIA, ≥ 12 GB VRAM, CUDA ≥ 11.8 (segmentation step only)\nWall clock : ~5 min/subject; ~3 h for a 100-subject cohort on 8 cores\n```\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#resource-requirements) for more details."},"title":{"changed":false},"uuid":"db78e5b1-1f01-47d1-a07c-2b1b349b400f","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:04:30.069Z","entityUuid":"1bc785f1-ee01-49b0-8c20-fa7578096490","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the project ship a complete environment specification beyond the language-level dependency manifest (see Documentation section)? Three patterns, in increasing rigor:\n- Lock-file plus README narrative.\n- Container image (Dockerfile, Apptainer recipe): gold standard, executable documentation.\n- Whole-environment spec (Nix, Pixi, conda-lock): bit-for-bit reproducibility.\n\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#containerisation-and-environment-specification) for more details."},"title":{"changed":false},"uuid":"2f10f9d5-8753-4121-bb16-2974260fa329"},{"annotations":[],"createdAt":"2026-06-08T13:05:03.961Z","entityUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","eventType":"AddQuestionEvent","parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"083de81d-5e70-4dc0-9d77-ef2ceaf42a66"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:05:05.033Z","entityUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What are the interfaces through which the software can be used?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#apis-and-interfaces) for more details."},"title":{"changed":true,"value":"Interfaces"},"uuid":"ed98bfe4-6ad0-4db1-a868-2967336e623a"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:05:17.306Z","entityUuid":"ba141448-f70d-4c95-b42c-be93a392936e","eventType":"EditChapterEvent","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","questionUuids":{"changed":true,"value":["d5af5796-82a6-4450-8e78-02f3d4ec049b","ed5d2980-ecaa-4654-a6a8-8a8dff5920fb","8bd89f26-dd51-47a8-b3df-131906f79db2","06b6d6d9-5942-4a2a-aecb-6bc9336505e3","6728ef06-49f0-481b-b337-8fc54d63ce6c","292e1a9c-0f32-4338-b558-1ea17e23cbb5","48321dbc-9069-437a-8a71-0fd37ab2d226","1bc785f1-ee01-49b0-8c20-fa7578096490"]},"text":{"changed":false},"title":{"changed":false},"uuid":"8b542032-9f73-40dc-87f5-75c15f4209fe"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:07:10.896Z","entityUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ba141448-f70d-4c95-b42c-be93a392936e","questionType":"ListQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"de478e18-2a3e-4349-804c-f1d8974897b1"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":true,"value":"What are the interfaces (e.g., CLI, API, web) through which the software can be used?\nSee [guidelines](https://lumc-dcc.github.io/rs-guidelines/best-practices/interoperability/#apis-and-interfaces) for more details."},"title":{"changed":false},"uuid":"077c05cf-b94e-47e5-8416-f419a1fadd39"},{"annotations":[],"createdAt":"2026-06-08T13:08:25.203Z","entityUuid":"3a92e33c-aa40-400f-8e2b-4c4c140090a0","eventType":"AddQuestionEvent","parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"b61fece0-f350-49f4-8122-2afb04c381ca"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:08:25.239Z","entityUuid":"3a92e33c-aa40-400f-8e2b-4c4c140090a0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Interface type"},"uuid":"7640c11b-f824-4b4d-826e-254e3b7b9f61"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:08:41.922Z","entityUuid":"3a92e33c-aa40-400f-8e2b-4c4c140090a0","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"de478e18-2a3e-4349-804c-f1d8974897b1"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"557b53ff-6938-46cd-8410-edfd2afd8b3f","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-06-08T13:08:54.775Z","entityUuid":"e0d5b6b8-a6d4-4df1-987e-07e8cd8516a4","eventType":"AddQuestionEvent","parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"446290d9-d286-4391-b52e-c28a81da2b0f"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:08:54.816Z","entityUuid":"e0d5b6b8-a6d4-4df1-987e-07e8cd8516a4","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Specification"},"uuid":"043fdf5f-4563-40a1-ab7c-cc5e9a0ae281"},{"annotations":[],"createdAt":"2026-06-08T13:09:27.448Z","entityUuid":"c127043f-524b-44b4-93d3-ff3ff82e889e","eventType":"AddQuestionEvent","parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"763f3342-caf8-4cb7-bfaf-a5dbba9e0c3c"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:09:27.485Z","entityUuid":"c127043f-524b-44b4-93d3-ff3ff82e889e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Status"},"uuid":"36880673-7146-45ea-9cc1-10148755066d"},{"annotations":{"changed":false},"createdAt":"2026-06-08T13:09:34.332Z","entityUuid":"c127043f-524b-44b4-93d3-ff3ff82e889e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"listQuestionUuid":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"ItemSelectQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":true,"value":"fd08c186-34f3-4104-8715-702e8623393c"},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"27de1785-4982-4bee-9fb2-e9ab18464589"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-06-08T13:10:00.095Z","entityUuid":"c127043f-524b-44b4-93d3-ff3ff82e889e","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"6728ef06-49f0-481b-b337-8fc54d63ce6c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"aa448577-a6a2-485c-9013-2cb35ae7272f"},{"advice":null,"annotations":[],"createdAt":"2026-06-08T13:10:05.141Z","entityUuid":"00d26d00-d877-462b-b34c-d9df8ec3d503","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"c127043f-524b-44b4-93d3-ff3ff82e889e","uuid":"bb5ac68f-c51a-4064-8cda-a460e742eb5b"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-06-08T13:10:06.178Z","entityUuid":"00d26d00-d877-462b-b34c-d9df8ec3d503","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"lab