ids":{"changed":false},"parentUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"0805f6ac-334c-4c92-a163-0c89e5b9eb9f","validations":{"changed":false},"valueType":{"changed":true,"value":"UrlQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T21:52:46.339Z","entityUuid":"4547d942-8960-43f1-9190-715fc3c84c21","eventType":"AddQuestionEvent","parentUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"fa84a2d4-8de6-4048-b681-3a9f69b9112d"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:52:46.367Z","entityUuid":"4547d942-8960-43f1-9190-715fc3c84c21","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"How does your software relate to it? E.g.: dependency, extends/forks, reimplements, alternative to, interoperates with."},"title":{"changed":true,"value":"Relationship"},"uuid":"2e48c627-14a4-44cb-8a1c-a1b88fe563e6"},{"annotations":[],"createdAt":"2026-05-10T21:53:22.875Z","entityUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","eventType":"AddQuestionEvent","parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"3dabe259-0d39-4c65-9fd8-8e1cedf045d0"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:53:26.083Z","entityUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does this software handle personal or otherwise sensitive data?\n\n- **Yes** if your code reads, stores, transmits or processes such data as part of its normal operation (e.g., a Castor extraction script, a clinical-decision-support API).\n- **User-supplied only** if your code is a generic library/CLI/tool that can be used with personal data when the user feeds it that data, but does not handle such data itself (e.g., a statistical analysis library, a plotting tool).\n- **No** if neither applies (e.g., a synthetic-data tool, a build-tool plugin)."},"title":{"changed":true,"value":"Personal / sensitive data handled"},"uuid":"0c27cd47-e8eb-4de8-a601-e49b9dab12e8"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T21:53:36.856Z","entityUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"4c82af44-c6b3-4c11-8f62-1fd0f1a51afb"},{"advice":{"changed":true,"value":"A separate LUMC Data Management Plan is likely required. Confirm with your division's privacy officer. See [LUMC Data Stewardship](https://www.albinusnet.nl/actueel/themas/datastewardship/)."},"annotations":{"changed":false},"createdAt":"2026-05-10T21:53:36.883Z","entityUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"09023194-111a-4ac6-b759-57689212d7a5"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T21:53:53.272Z","entityUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"07c902ad-d162-4ee9-a66a-864e0f7184a6"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T21:53:55.302Z","entityUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"User-supplied only"},"metricMeasures":{"changed":false},"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"26e7f4da-663f-40dd-9729-e35203f988c7"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T21:53:59.704Z","entityUuid":"e10ae8ce-4990-4aa6-b232-48484b03d4fa","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"b61197f4-69fa-4407-b572-189b2e5764b1"},{"advice":{"changed":true,"value":"\"No\" means: no personal data, no clinical data, no patient-derived data, no contact data of identifiable people, no data covered by an institutional sensitivity policy. If your software might in the future be applied to such data by a downstream user, that's covered under User-supplied only - pick that instead."},"annotations":{"changed":false},"createdAt":"2026-05-10T21:53:59.726Z","entityUuid":"e10ae8ce-4990-4aa6-b232-48484b03d4fa","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"9ffa6c58-87eb-41cc-b161-39501bf4a4a3","uuid":"6aa00dcd-8da5-46f1-bbfd-03dbe3d551c8"},{"annotations":[],"createdAt":"2026-05-10T21:54:05.576Z","entityUuid":"823a9b7b-5627-4d01-a136-06a2f19a0455","eventType":"AddQuestionEvent","parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"cf8bb5dc-1efe-490a-b5ac-3c9ae7d9cac2"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:54:06.601Z","entityUuid":"823a9b7b-5627-4d01-a136-06a2f19a0455","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Link to or identifier of the corresponding Data Management Plan."},"title":{"changed":true,"value":"DMP reference"},"uuid":"10d7b1af-6e46-4bce-b822-711c4a5dcaad"},{"annotations":{"changed":false},"createdAt":"2026-05-10T21:54:13.342Z","entityUuid":"823a9b7b-5627-4d01-a136-06a2f19a0455","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"cab54b67-8652-4625-a522-ce3a1bf4eaf0","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T21:54:21.89Z","entityUuid":"ddb3fe31-c887-43f8-9651-77324d26f8b3","eventType":"AddQuestionEvent","parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"6f148c8c-8ee1-4848-a5c6-6014434e0804"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:54:22.927Z","entityUuid":"ddb3fe31-c887-43f8-9651-77324d26f8b3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What categories of personal or sensitive data does the software handle? (E.g., pseudonymized clinical records, identifiable imaging, genetic variants)."},"title":{"changed":true,"value":"Data categories"},"uuid":"5746fe05-5247-4edd-90dd-977e88e8ffe6"},{"annotations":{"changed":false},"createdAt":"2026-05-10T21:54:27.27Z","entityUuid":"ddb3fe31-c887-43f8-9651-77324d26f8b3","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"c9ae2467-ef0d-4eae-898e-8fcd00cacc31","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T21:54:45.372Z","entityUuid":"0a4c4dce-1969-48e1-a6e8-32dce8425d59","eventType":"AddQuestionEvent","parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"fd155ffe-caa8-4ec7-9650-f83fb0ad7104"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:54:46.415Z","entityUuid":"0a4c4dce-1969-48e1-a6e8-32dce8425d59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"What is the contingency plan if something fails? What are the responsibilities, escalation procedures, and commitments in the event of a failure?\nMitigations don't have to be elaborate.\n\nIf the mitigation risks are outlined in the DMP, say so explicitly."},"title":{"changed":true,"value":"Mitigation"},"uuid":"ddf61137-b46a-45e8-9cfd-947094f1900c"},{"annotations":{"changed":false},"createdAt":"2026-05-10T21:54:53.513Z","entityUuid":"0a4c4dce-1969-48e1-a6e8-32dce8425d59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"dcba8e26-64b4-4fc5-86aa-4a42178c383a","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"017f3ce8-1c48-4bd4-896e-9c27a16306f4","validations":{"changed":false},"valueType":{"changed":true,"value":"TextQuestionValueType"}},{"annotations":{"changed":false},"createdAt":"2026-05-10T21:55:20.436Z","entityUuid":"4547d942-8960-43f1-9190-715fc3c84c21","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"0fe887b5-a6eb-497b-ab6a-05c0c362a59b","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"3921cf3f-7f74-4f49-bdaa-49cc66faa7b9","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T21:55:38.956Z","entityUuid":"8b4d40a6-3be6-40b5-8219-b3f4431a4c40","eventType":"AddQuestionEvent","parentUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"0439f90b-53ec-4481-ba55-dee0418c7a1c"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:55:38.986Z","entityUuid":"8b4d40a6-3be6-40b5-8219-b3f4431a4c40","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Briefly describe the design choices that prevent inadvertent data leakage: no telemetry by default, no caching of inputs, log scrubbing, clear instructions for users to anonymize upstream or run in a controlled environment."},"title":{"changed":true,"value":"Mitigation"},"uuid":"5d94bfc4-0661-4175-b2c6-2544035e5477"},{"annotations":{"changed":false},"createdAt":"2026-05-10T21:55:57.147Z","entityUuid":"8b4d40a6-3be6-40b5-8219-b3f4431a4c40","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"01ca2df0-f2e3-4615-ac62-c7b9db656bd2","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"a2c79455-d80a-403d-b2e7-e6e89fffe3f0","validations":{"changed":false},"valueType":{"changed":true,"value":"TextQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T21:56:44.303Z","entityUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","eventType":"AddQuestionEvent","parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"634f4c6f-059e-4d1b-82af-6291284ea920"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:56:46.334Z","entityUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the software face operational security obligations: authentication, authorization, input sanitization, secret management, vulnerability scanning?\n\nThese usually apply to services, APIs, and daemons. Pure libraries, scripts, and notebooks normally do not face these obligations directly"},"title":{"changed":true,"value":"Security & access control"},"uuid":"765cceba-0454-4579-b4cf-32c405d58e08"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T21:57:03.74Z","entityUuid":"98569a9f-cf37-4451-9d20-4836b8187578","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","uuid":"cc8c9f1b-c34e-4503-91ad-f04a4377f148"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T21:57:04.77Z","entityUuid":"98569a9f-cf37-4451-9d20-4836b8187578","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","uuid":"ce4e51a0-b1a2-4603-a2a1-74ee8ee864c9"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T21:57:06.859Z","entityUuid":"b3df6c02-d8b5-48c8-8097-510cb155e85e","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","uuid":"cd813ba3-a70c-4cd4-8808-8ef8c72b2cbb"},{"advice":{"changed":true,"value":"\"No\" is correct for libraries and analysis pipelines that don't authenticate users, don't expose network endpoints, and don't process secrets."},"annotations":{"changed":false},"createdAt":"2026-05-10T21:57:07.065Z","entityUuid":"b3df6c02-d8b5-48c8-8097-510cb155e85e","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"8eb03e74-d9d9-49ca-9f7f-4d15c8b85874","uuid":"de213897-7f78-4420-9d9f-62084dc517d5"},{"annotations":[],"createdAt":"2026-05-10T21:57:51.936Z","entityUuid":"a0bba8ec-693f-40b2-9f2a-04beb736c8b1","eventType":"AddQuestionEvent","parentUuid":"98569a9f-cf37-4451-9d20-4836b8187578","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"73cf7af2-6533-4886-b0ff-98c7e947077e"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T21:57:53.969Z","entityUuid":"a0bba8ec-693f-40b2-9f2a-04beb736c8b1","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"98569a9f-cf37-4451-9d20-4836b8187578","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":true,"value":"Security measures"},"uuid":"cf53a431-777c-4965-a79e-644a6c9e8644"},{"annotations":{"changed":false},"choiceUuids":{"changed":false},"createdAt":"2026-0