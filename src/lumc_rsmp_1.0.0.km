d":false},"createdAt":"2026-05-10T22:01:51.3Z","entityUuid":"b3a7d009-8c2d-492a-88e2-37f79a1c7f67","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"cb896475-0d05-4cf4-8761-3fb3c0ee9223","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"e4580139-adab-4971-8e7c-6948dc45950c","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T22:02:04.56Z","entityUuid":"1e3700a0-0ebe-4499-a95c-caa6eb2b2974","eventType":"AddQuestionEvent","parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"6c5d0d97-3b97-4eef-bd6d-ba474e884034"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:02:04.583Z","entityUuid":"1e3700a0-0ebe-4499-a95c-caa6eb2b2974","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"93c0dcb5-0d56-44af-8b2d-10c4fbef13ef","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Does the software face (long-term) risks in external software, data, hardware or services whose behavior, availability, or license?"},"title":{"changed":true,"value":"External dependencies"},"uuid":"3be5f78b-51a8-46ac-afd1-d11bbbad438c"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T22:02:12.159Z","entityUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"1e3700a0-0ebe-4499-a95c-caa6eb2b2974","uuid":"15920d4e-7e2e-4d48-b060-3b407536c535"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:02:12.202Z","entityUuid":"6ff80d99-bb0e-47e6-a450-4e17f9439424","eventType":"Edi