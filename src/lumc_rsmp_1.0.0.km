:true,"value":"Code quality standards"},"uuid":"6b909d81-7d7e-4eba-8d64-e1eccd2283ec"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T22:47:10.177Z","entityUuid":"206e6275-d142-4d29-8444-8f003555a0a1","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","uuid":"97a53f50-e9c4-40b0-88b5-ae9c7cb0ecad"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:47:11.21Z","entityUuid":"206e6275-d142-4d29-8444-8f003555a0a1","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes"},"metricMeasures":{"changed":false},"parentUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","uuid":"2782eacc-be1c-4904-a0ad-b15dc7c9a855"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T22:47:13.41Z","entityUuid":"172ae40e-98e8-421b-8c18-bfb9c3e92a28","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","uuid":"25ced00d-64cd-4a4b-a051-b1834c5378dc"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:47:13.472Z","entityUuid":"172ae40e-98e8-421b-8c18-bfb9c3e92a28","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"No"},"metricMeasures":{"changed":false},"parentUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","uuid":"330cc1b5-8ca4-4faa-badf-223221ba65a1"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:47:18.167Z","entityUuid":"206e6275-d142-4d29-8444-8f003555a0a1","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":false},"metricMeasures":{"changed":true,"value":[{"measure":1,"metricUuid":"b681c5fb-2a05-4e19-be0e-6e5ccd13b58f","weight":0.5},{"measure":1,"metricUuid":"2a7fe444-029f-41e3-aae4-ae6b0645b4d4","weight":0.5}]},"parentUuid":"a96f0cb4-6796-40e2-be52-88331d9ce1a9","uuid":"aaf00339-a3e1-472a-ab9a-5e50f91fc8d4"},{"advice":{"changed":true,"value":