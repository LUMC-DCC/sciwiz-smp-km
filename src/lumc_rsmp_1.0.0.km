rsioning, and archiving.  (read more doi.org/10.5281/zenodo.7589725)"},"entityUuid":"f137aaf2-c1a7-429b-b498-2c80eb9f2a7d","eventType":"EditTagEvent","name":{"changed":true,"value":"Level A"},"parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","uuid":"748a4c64-3a0b-4758-8fae-7808194f6d1d"},{"annotations":[],"color":"","createdAt":"2026-05-10T23:10:22.496Z","description":null,"entityUuid":"92650c80-a463-4b49-869e-d6cfa63fe564","eventType":"AddTagEvent","name":"","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","uuid":"5d6dc99b-cac8-4bf9-82f3-0e23764ec60e"},{"annotations":{"changed":false},"color":{"changed":true,"value":"#8E44AD"},"createdAt":"2026-05-10T23:10:22.526Z","description":{"changed":true,"value":"This software is typically a research output developed for a project but may be useful to others as a tool, module, or library. It should follow solid software practices - like version control, documentation, testing, and packaging - to ensure reliability and reusability. Because it can outlive the project, plans for archiving, citation, and long-term support are necessary.  (read more doi.org/10.5281/zenodo.7589725)"},"entityUuid":"92650c80-a463-4b49-869e-d6cfa63fe564","eventType":"EditTagEvent","name":{"changed":true,"value":"Level B"},"parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","uuid":"5d5e6d36-0919-44d9-88d6-167d087397d9"},{"annotations":[],"color":"","createdAt":"2026-05-10T23:10:31.162Z","description":null,"entityUuid":"b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","eventType":"AddTagEvent","name":"","parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","uuid":"94f7bdf3-b08d-4c22-8e92-49c3103cffaa"},{"annotations":{"changed":false},"color":{"changed":true,"value":"#E67E22"},"createdAt":"2026-05-10T23:10:31.193Z","description":{"changed":true,"value":"This software has broad impact or critical use, such as being used by external users or influencing research results, models, or physical systems. Reliability is essential and requires rigorous engineering practices, testing, auditing, and compliance with legal or certification standards. It must be maintained indefinitely, supported by sustainable funding, community involvement, and continuous release pipelines."},"entityUuid":"b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","eventType":"EditTagEvent","name":{"changed":true,"value":"Level C"},"parentUuid":"414f5370-df93-4b98-8289-58b881d81ceb","uuid":"00cad124-79c4-4849-9d06-ba0eb454e9f2"},{"annotations":{"changed":false},"createdAt":"2026-05-10T23:10:50.157Z","entityUuid":"68f0beb6-eaf7-4f1a-b7a3-b6cc0c875a38","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564","f137aaf2-c1a7-429b-b498-2c80eb9f2a7d"]},"text":{"changed":false},"title":{"changed":false},"uuid":"b14db5d0-8020-48d4-8858-de68a067d284","validations":{"changed":false},"valueType":{"changed":false}},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T23:10:52.9Z","entityUuid":"c21e449e-8b43-403f-be68-dcb9e3abe7ba","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"a86be77f-e97d-49f9-a5f3-4af5105367e3","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":true,"value":["b3e257d2-eaaf-4d22-89c9-3024eb7f2f3e","92650c80-a463-4b49-869e-d6cfa63fe564"]},"text":{"changed":false},"title":{"changed":false},"uuid":"ce0baf57-fdc3-40b7-925e-a953d794b713"},{"annotations":{"changed":false},"createdAt":"2026-05-10T23:10:57.368Z","entityUuid":"7ef49f2e-9981-421b-8a23-d1c5f181c741","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"itemTemplateQuestionUuids":{"changed":false},"parentUuid":"ef2a2194-5a5c-4eca-bac2-3d79fbeac9a7","questionType":"ListQuestion","refer