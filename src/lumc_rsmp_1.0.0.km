,"uuid":"f6d51466-4b12-40c8-af13-b4f9a917402f"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:25:30.938Z","entityUuid":"aebefa3a-9909-4de4-8d9e-fc550500f9ee","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ce2b567a-da20-43be-a121-e677415a8e0c","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Pick the license (use the [SPDX identifier](https://spdx.org/licenses/): `Apache-2.0`, not `Apache 2.0`). \nLUMC default: **\"as open as possible, as closed as necessary\"**.\nRecommended license: [Apache-2.0](https://www.apache.org/licenses/LICENSE-2.0)."},"title":{"changed":false},"uuid":"294a95bc-abf1-4ae9-90c2-88110cbe5ec1","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T22:25:52.377Z","entityUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","eventType":"AddQuestionEvent","parentUuid":"ce2b567a-da20-43be-a121-e677415a8e0c","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"33ceaf0c-6192-4906-a674-3341edc36e65"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:25:52.422Z","entityUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"ce2b567a-da20-43be-a121-e677415a8e0c","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Do you check if your dependencies' licenses are compatible with your project's license?\n\nLicense compatibility means the licenses of your project and its dependencies don't conflict legally. It matters when you use third-party code, such as libraries or modules, because incompatible licenses can block you from distributing your software, force you to adopt more restrictive terms, or even introduce legal risk.\n\nTooling: licensecheck / pip-licenses (Python), cargo-deny (Rust), license-checker (Node), FOSSA / Snyk / GitHub Advanced Security (cross-language)."},"title":{"changed":true,"value":"License compatibility"},"uuid":"1b5790c2-e5d6-4548-ba5d-4e24675949ff"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T22:26:03.693Z","entityUuid":"f4cf03cd-6b28-41a5-b1ee-0e510f9c51e5","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","uuid":"cb4685a8-4ac2-4b54-98f7-5ebe8a487296"},{"advice":{"changed":false},"annotations":{"changed":false},"createdAt":"2026-05-10T22:26:06.738Z","entityUuid":"f4cf03cd-6b28-41a5-b1ee-0e510f9c51e5","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes - automated tooling"},"metricMeasures":{"changed":true,"value":[{"measure":1,"metricUuid":"b681c5fb-2a05-4e19-be0e-6e5ccd13b58f","weight":0.5},{"measure":1,"metricUuid":"2a7fe444-029f-41e3-aae4-ae6b0645b4d4","weight":0.5}]},"parentUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","uuid":"b8388d18-a271-4df7-8299-6a941c7fa5fa"},{"advice":null,"annotations":[],"createdAt":"2026-05-10T22:26:24.182Z","entityUuid":"d9f66fa4-4d0e-4ed8-9786-68dfa63dc8a5","eventType":"AddAnswerEvent","label":"","metricMeasures":[],"parentUuid":"8fe87903-df9b-4e85-8f80-471a46e20e59","uuid":"51159cf6-1fdd-4475-a4e0-bed8594d214c"},{"advice":{"changed":true,"value":"Manual checks are fragile. Acceptable for small projects with few dependencies."},"annotations":{"changed":false},"createdAt":"2026-05-10T22:26:25.226Z","entityUuid":"d9f66fa4-4d0e-4ed8-9786-68dfa63dc8a5","eventType":"EditAnswerEvent","followUpUuids":{"changed":false},"label":{"changed":true,"value":"Yes - manual check"},"metricMeasures":{"changed":true,"value":[{"measure":0.75,"metricUuid":"b681c5fb-2a05-4e19-be0e-6e5ccd13b58f","weight":0.5},{"measure":0.75,"metricUuid":"2a7fe444-029f-41e3-aae4-a