 per year`. 0 is acceptable, but only if you have an explicit retirement plan."},"title":{"changed":true,"value":"Effort in maintenance"},"uuid":"53ce8b7f-4284-4473-b1d7-a7f6da7e3945"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:09:52.34Z","entityUuid":"ffbaf875-9ada-42cd-ad34-046a55ee4eab","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"61a3dcff-803f-41c3-9e14-5fa1fb5492c3","questionType":"ValueQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":false},"title":{"changed":false},"uuid":"bf86c7e6-2996-4e69-89e7-3a471ed9f1fe","validations":{"changed":false},"valueType":{"changed":true,"value":"StringQuestionValueType"}},{"annotations":[],"createdAt":"2026-05-10T22:09:59.107Z","entityUuid":"6438ee04-535a-4991-ac67-b3e2c924a058","eventType":"AddQuestionEvent","parentUuid":"61a3dcff-803f-41c3-9e14-5fa1fb5492c3","questionType":"OptionsQuestion","requiredPhaseUuid":null,"tagUuids":[],"text":null,"title":"","uuid":"0e3bf4b1-0a3b-4c23-a666-763b5a6ed291"},{"annotations":{"changed":false},"answerUuids":{"changed":false},"createdAt":"2026-05-10T22:10:00.136Z","entityUuid":"6438ee04-535a-4991-ac67-b3e2c924a058","eventType":"EditQuestionEvent","expertUuids":{"changed":false},"parentUuid":"61a3dcff-803f-41c3-9e14-5fa1fb5492c3","questionType":"OptionsQuestion","referenceUuids":{"changed":false},"requiredPhaseUuid":{"changed":false},"tagUuids":{"changed":false},"text":{"changed":true,"value":"Describe what happens if the main developer, maintainer, funding source, or infrastructure becomes unavailable.\n\nExamples of viable answers: backup maintainer with full rights; community fork on day one; archived repository; hand-over to <new responsible entity> at end of grant."},"title":{"changed":true,"value":"Continuity plan"},"uuid":"d3c08143-cb80-4920-a74d-60543be6aa64"},{"annotations":{"changed":false},"createdAt":"2026-05-10T22:10:05.101Z","entityUuid":"6438ee04-